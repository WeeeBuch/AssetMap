      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.VisualStudio.Azure.Containers.Tools.Targets" Version="1.23.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\AssetMap.Core\AssetMap.Core.csproj" />
    <ProjectReference Include="..\AssetMap.Database\AssetMap.Database.csproj" />
    <ProjectReference Include="..\AssetMap.Comms\AssetMap.Comms.csproj" />
  </ItemGroup>

</Project>
