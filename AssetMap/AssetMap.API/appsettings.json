{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // API klíč — nastav nebo přepiš env proměnnou ASSETMAP_API_KEY
  // Pokud je prázdný, API je přístupné bez autentizace (pouze pro localhost dev)
  "ApiKey": "",

  // DB_PROVIDER: "sqlite" nebo "postgres"
  // DB_CONNECTION: connection string (pro SQLite cesta k souboru, pro postgres host=...)
  // Výchozí: SQLite v ~/.assetmap/data.db
  "DB_PROVIDER": "sqlite",
  "DB_CONNECTION": ""
}
