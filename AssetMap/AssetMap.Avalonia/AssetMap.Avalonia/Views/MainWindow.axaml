<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AssetMap.Avalonia.ViewModels"
        xmlns:views="using:AssetMap.Avalonia.Views"
        x:Class="AssetMap.Avalonia.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="AssetMap"
        Icon="avares://AssetMap.Avalonia/Assets/Icon.ico"
        MinWidth="900" MinHeight="600"
        Width="1200" Height="750"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BrushBackground}">

    <Window.Styles>
        <!-- Nav tlačítka v sidebaru -->
        <Style Selector="Button.nav">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="Foreground"                 Value="{DynamicResource BrushTextSecondary}"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="CornerRadius"               Value="6"/>
            <Setter Property="Padding"                    Value="10 8"/>
            <Setter Property="HorizontalAlignment"        Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FontSize"                   Value="13"/>
            <Setter Property="Cursor"                     Value="Hand"/>
        </Style>
        <Style Selector="Button.nav /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.nav:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
        </Style>
        <Style Selector="Button.nav:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BrushSurface}"/>
        </Style>
        <Style Selector="Button.nav.active">
            <Setter Property="Foreground" Value="{DynamicResource BrushAccent}"/>
        </Style>
        <Style Selector="Button.nav.active /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BrushSurface}"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="Auto,*">

        <!-- ══════════════════════ SIDEBAR ══════════════════════ -->
        <Border Grid.Column="0"
                Width="{Binding SidebarWidth}"
                Background="{DynamicResource BrushSurfaceAlt}"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="0 0 1 0"
                ClipToBounds="True">
            <DockPanel>

                <!-- Logo -->
                <Border DockPanel.Dock="Top" Padding="12 18 12 12">
                    <Grid Height="32">
                        <!-- Otevřeno: ikona + název -->
                        <StackPanel Orientation="Horizontal" Spacing="10"
                                    IsVisible="{Binding IsSidebarOpen}"
                                    VerticalAlignment="Center">
                            <Border Width="40" Height="40" CornerRadius="12"
                                    ClipToBounds="True">
                                <Image Source="avares://AssetMap.Avalonia/Assets/Icon.png"
                                       RenderOptions.BitmapInterpolationMode="HighQuality"/>
                            </Border>
                            <TextBlock Text="AssetMap" FontSize="15" FontWeight="Bold"
                                       Foreground="{DynamicResource BrushTextPrimary}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Zavřeno: jen ikona, vycentrovaná -->
                        <Border Width="40" Height="40" CornerRadius="12"
                                ClipToBounds="True"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                IsVisible="{Binding !IsSidebarOpen}">
                            <Image Source="avares://AssetMap.Avalonia/Assets/Icon.png"
                                   RenderOptions.BitmapInterpolationMode="HighQuality"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Separator -->
                <Border DockPanel.Dock="Top" Height="1"
                        Background="{DynamicResource BrushBorder}"
                        Margin="0 0 0 6"/>

                <!-- Spodní oblast: Settings + Toggle -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="{DynamicResource BrushBorder}"
                        BorderThickness="0 1 0 0"
                        Padding="8 6">
                    <StackPanel Spacing="2">

                        <Button Classes="nav"
                                Classes.active="{Binding IsOnSettings}"
                                Command="{Binding NavigateToSettingsCommand}"
                                ToolTip.Tip="Nastavení">
                            <Grid>
                                <StackPanel Orientation="Horizontal" Spacing="10"
                                            IsVisible="{Binding IsSidebarOpen}">
                                    <TextBlock Text="⚙" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Nastavení" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="⚙" FontSize="14"
                                           IsVisible="{Binding !IsSidebarOpen}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>

                        <!-- Collapse / Expand tlačítko -->
                        <Button Classes="nav"
                                Command="{Binding ToggleSidebarCommand}"
                                ToolTip.Tip="Skrýt / zobrazit panel">
                            <Grid>
                                <TextBlock Text="‹ Skrýt" FontSize="12"
                                           IsVisible="{Binding IsSidebarOpen}"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="›" FontSize="16"
                                           IsVisible="{Binding !IsSidebarOpen}"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>

                    </StackPanel>
                </Border>

                <!-- Navigace -->
                <StackPanel DockPanel.Dock="Top" Margin="8 4" Spacing="2">

                    <TextBlock Text="PŘEHLED"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               Margin="12 6 0 4" Opacity="0.7"
                               IsVisible="{Binding IsSidebarOpen}"/>

                    <Button Classes="nav"
                            Classes.active="{Binding IsOnDashboard}"
                            Command="{Binding NavigateToDashboardCommand}"
                            ToolTip.Tip="Dashboard">
                        <Grid>
                            <StackPanel Orientation="Horizontal" Spacing="10"
                                        IsVisible="{Binding IsSidebarOpen}">
                                <TextBlock Text="◈" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="◈" FontSize="14"
                                       IsVisible="{Binding !IsSidebarOpen}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <TextBlock Text="SPRÁVA"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               Margin="12 10 0 4" Opacity="0.7"
                               IsVisible="{Binding IsSidebarOpen}"/>

                    <Button Classes="nav"
                            Classes.active="{Binding IsOnAccounts}"
                            Command="{Binding NavigateToAccountsCommand}"
                            ToolTip.Tip="Účty">
                        <Grid>
                            <StackPanel Orientation="Horizontal" Spacing="10"
                                        IsVisible="{Binding IsSidebarOpen}">
                                <TextBlock Text="⬡" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="Účty" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="⬡" FontSize="14"
                                       IsVisible="{Binding !IsSidebarOpen}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button Classes="nav"
                            Classes.active="{Binding IsOnTransactions}"
                            Command="{Binding NavigateToTransactionsCommand}"
                            ToolTip.Tip="Transakce">
                        <Grid>
                            <StackPanel Orientation="Horizontal" Spacing="10"
                                        IsVisible="{Binding IsSidebarOpen}">
                                <TextBlock Text="↕" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="Transakce" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="↕" FontSize="14"
                                       IsVisible="{Binding !IsSidebarOpen}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button Classes="nav"
                            Classes.active="{Binding IsOnAssets}"
                            Command="{Binding NavigateToAssetsCommand}"
                            ToolTip.Tip="Aktiva">
                        <Grid>
                            <StackPanel Orientation="Horizontal" Spacing="10"
                                        IsVisible="{Binding IsSidebarOpen}">
                                <TextBlock Text="▦" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="Aktiva" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="▦" FontSize="14"
                                       IsVisible="{Binding !IsSidebarOpen}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                </StackPanel>

                <Grid/>
            </DockPanel>
        </Border>

        <!-- ══════════════════════ MAIN AREA ══════════════════════ -->
        <Grid Grid.Column="1" RowDefinitions="56,*">

            <!-- Topbar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource BrushSurface}"
                    BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="0 0 0 1"
                    Padding="24 0">
                <Grid ColumnDefinitions="*,Auto,Auto">

                    <!-- Offline banner -->
                    <Border Grid.Column="1"
                            Background="#30FF9900"
                            BorderBrush="#70FF9900"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10 4"
                            Margin="0 0 12 0"
                            VerticalAlignment="Center"
                            IsVisible="{Binding IsOffline}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="⚡" FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding OfflineBannerText}"
                                       FontSize="11" FontWeight="Medium"
                                       Foreground="#FFCC66"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{Binding PageTitle}"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource BrushTextPrimary}"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <Button Classes="ghost" Padding="7" CornerRadius="6">
                            <TextBlock Text="🔔" FontSize="14"/>
                        </Button>
                        <Border Width="32" Height="32" CornerRadius="16">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                    <GradientStop Color="#FF0078D4" Offset="0"/>
                                    <GradientStop Color="#FF00B4D8" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="U" Foreground="White"
                                       FontWeight="Bold" FontSize="13"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Obsah stránky -->
            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <Panel>
                    <views:MainView Margin="24"
                                    IsVisible="{Binding IsOnDashboard}"/>
                    <Panel IsVisible="{Binding IsOnAccounts}">
                        <views:AccountsView Margin="24"
                                            DataContext="{Binding AccountsVM}"/>
                    </Panel>
                    <Panel IsVisible="{Binding IsOnTransactions}">
                        <views:TransactionsView Margin="24"
                                                DataContext="{Binding TransactionsVM}"/>
                    </Panel>
                    <Panel IsVisible="{Binding IsOnAssets}">
                        <views:AssetsView Margin="24"
                                          DataContext="{Binding AssetsVM}"/>
                    </Panel>
                    <views:SettingsView Margin="24"
                                        IsVisible="{Binding IsOnSettings}"/>
                </Panel>
            </ScrollViewer>

            <!-- ══════════════════════════════════
                 MODAL — PŘIDAT / UPRAVIT ÚČET
                 Viewport-fixed: mimo ScrollViewer
                 ══════════════════════════════════ -->
            <Panel Grid.Row="0" Grid.RowSpan="2"
                   IsVisible="{Binding AccountsVM.IsAddDialogOpen}">
                <Panel DataContext="{Binding AccountsVM}"
                       x:DataType="vm:AccountsViewModel">

                    <!-- Backdrop -->
                    <Border Background="#B2000000"/>

                    <!-- Dialog card -->
                    <Border Width="480"
                            CornerRadius="14"
                            Background="{DynamicResource BrushSurface}"
                            BorderBrush="{DynamicResource BrushBorder}"
                            BorderThickness="1"
                            Padding="28 24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            BoxShadow="0 12 48 4 #70000000">
                        <StackPanel Spacing="0">

                            <!-- Hlavička -->
                            <Grid ColumnDefinitions="*,Auto" Margin="0 0 0 22">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding AddDialogTitle}"
                                           FontSize="17" FontWeight="SemiBold"
                                           Foreground="{DynamicResource BrushTextPrimary}"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1"
                                        Classes="ghost"
                                        Command="{Binding CancelAddAccountCommand}"
                                        Width="30" Height="30" Padding="0" CornerRadius="8">
                                    <TextBlock Text="✕" FontSize="13"
                                               Foreground="{DynamicResource BrushTextSecondary}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                            </Grid>

                            <!-- ── Název ─── -->
                            <TextBlock Text="Název *"
                                       FontSize="12" FontWeight="Medium"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       Margin="0 0 0 5"/>
                            <TextBox Text="{Binding AddName}"
                                     PlaceholderText="např. Běžný účet"
                                     Margin="0 0 0 14"/>

                            <!-- ── Instituce ─── -->
                            <TextBlock Text="Instituce / Poskytovatel"
                                       FontSize="12" FontWeight="Medium"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       Margin="0 0 0 5"/>
                            <TextBox Text="{Binding AddInstitution}"
                                     PlaceholderText="např. Česká spořitelna"
                                     Margin="0 0 0 16"/>

                            <!-- ── Typ účtu ─── -->
                            <TextBlock Text="Typ účtu"
                                       FontSize="12" FontWeight="Medium"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       Margin="0 0 0 8"/>
                            <Border CornerRadius="8"
                                    Background="{DynamicResource BrushSurfaceAlt}"
                                    BorderBrush="{DynamicResource BrushBorder}"
                                    BorderThickness="1"
                                    Padding="3"
                                    HorizontalAlignment="Left"
                                    Margin="0 0 0 16">
                                <StackPanel Orientation="Horizontal" Spacing="0">
                                    <Button Classes="seg" Classes.on="{Binding AddIsTypeBank}"
                                            Command="{Binding AddSetTypeBankCommand}"
                                            Content="🏦 Banka"/>
                                    <Button Classes="seg" Classes.on="{Binding AddIsTypeCrypto}"
                                            Command="{Binding AddSetTypeCryptoCommand}"
                                            Content="₿ Krypto"/>
                                    <Button Classes="seg" Classes.on="{Binding AddIsTypeBrokerage}"
                                            Command="{Binding AddSetTypeBrokerageCommand}"
                                            Content="📈 Broker"/>
                                    <Button Classes="seg" Classes.on="{Binding AddIsTypeCash}"
                                            Command="{Binding AddSetTypeCashCommand}"
                                            Content="💵 Hotovost"/>
                                </StackPanel>
                            </Border>

                            <!-- ── Barva účtu ─── -->
                            <TextBlock Text="Barva ikony"
                                       FontSize="12" FontWeight="Medium"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       Margin="0 0 0 8"/>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0 0 0 16">
                                <Panel Width="34" Height="34">
                                    <Border Width="34" Height="34" CornerRadius="17" BorderBrush="{DynamicResource BrushAccent}" BorderThickness="2.5" IsVisible="{Binding IsAddColor0}"/>
                                    <Button Classes="ghost" Width="26" Height="26" Padding="0" CornerRadius="13" Command="{Binding AddSelectColor0Command}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border Width="22" Height="22" CornerRadius="11" Background="#4263EB"/>
                                    </Button>
                                </Panel>
                                <Panel Width="34" Height="34">
                                    <Border Width="34" Height="34" CornerRadius="17" BorderBrush="{DynamicResource BrushAccent}" BorderThickness="2.5" IsVisible="{Binding IsAddColor1}"/>
                                    <Button Classes="ghost" Width="26" Height="26" Padding="0" CornerRadius="13" Command="{Binding AddSelectColor1Command}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border Width="22" Height="22" CornerRadius="11" Background="#00B3FF"/>
                                    </Button>
                                </Panel>
                                <Panel Width="34" Height="34">
                                    <Border Width="34" Height="34" CornerRadius="17" BorderBrush="{DynamicResource BrushAccent}" BorderThickness="2.5" IsVisible="{Binding IsAddColor2}"/>
                                    <Button Classes="ghost" Width="26" Height="26" Padding="0" CornerRadius="13" Command="{Binding AddSelectColor2Command}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border Width="22" Height="22" CornerRadius="11" Background="#00E57A"/>
                                    </Button>
                                </Panel>
                                <Panel Width="34" Height="34">
                                    <Border Width="34" Height="34" CornerRadius="17" BorderBrush="{DynamicResource BrushAccent}" BorderThickness="2.5" IsVisible="{Binding IsAddColor3}"/>
                                    <Button Classes="ghost" Width="26" Height="26" Padding="0" CornerRadius="13" Command="{Binding AddSelectColor3Command}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border Width="22" Height="22" CornerRadius="11" Background="#12B886"/>
                                    </Button>
                                </Panel>
                                <Panel Width="34" Height="34">
                                    <Border Width="34" Height="34" CornerRadius="17" BorderBrush="{DynamicResource BrushAccent}" BorderThickness="2.5" IsVisible="{Binding IsAddColor4}"/>
                                    <Button Classes="ghost" Width="26" Height="26" Padding="0" CornerRadius="13" Command="{Binding AddSelectColor4Command}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border Width="22" Height="22" CornerRadius="11" Background="#F7931A"/>
                                    </Button>
                                </Panel>
                                <Panel Width="34" Height="34">
                                    <Border Width="34" Height="34" CornerRadius="17" BorderBrush="{DynamicResource BrushAccent}" BorderThickness="2.5" IsVisible="{Binding IsAddColor5}"/>
                                    <Button Classes="ghost" Width="26" Height="26" Padding="0" CornerRadius="13" Command="{Binding AddSelectColor5Command}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border Width="22" Height="22" CornerRadius="11" Background="#FF3355"/>
                                    </Button>
                                </Panel>
                                <Panel Width="34" Height="34">
                                    <Border Width="34" Height="34" CornerRadius="17" BorderBrush="{DynamicResource BrushAccent}" BorderThickness="2.5" IsVisible="{Binding IsAddColor6}"/>
                                    <Button Classes="ghost" Width="26" Height="26" Padding="0" CornerRadius="13" Command="{Binding AddSelectColor6Command}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border Width="22" Height="22" CornerRadius="11" Background="#845EF7"/>
                                    </Button>
                                </Panel>
                                <Panel Width="34" Height="34">
                                    <Border Width="34" Height="34" CornerRadius="17" BorderBrush="{DynamicResource BrushAccent}" BorderThickness="2.5" IsVisible="{Binding IsAddColor7}"/>
                                    <Button Classes="ghost" Width="26" Height="26" Padding="0" CornerRadius="13" Command="{Binding AddSelectColor7Command}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border Width="22" Height="22" CornerRadius="11" Background="#8B8B9A"/>
                                    </Button>
                                </Panel>
                            </StackPanel>

                            <!-- ── Aktivum / Symbol ─── -->
                            <StackPanel IsVisible="{Binding AddShowAssetSection}">
                                <TextBlock Text="Aktivum / Symbol *"
                                           FontSize="12" FontWeight="Medium"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           Margin="0 0 0 5"/>
                                <TextBox Text="{Binding AddAssetText}"
                                         PlaceholderText="{Binding AddAssetPlaceholder}"
                                         Margin="0 0 0 4"/>

                                <!-- Status hledání -->
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0 0 0 12"
                                            IsVisible="{Binding AddIsAssetSearching}">
                                    <TextBlock Text="⏳" FontSize="11"/>
                                    <TextBlock Text="Hledám na CoinGecko…"
                                               FontSize="11" Foreground="{DynamicResource BrushTextSecondary}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0 0 0 12"
                                            IsVisible="{Binding AddIsAssetFound}">
                                    <TextBlock Text="✓" FontSize="11" FontWeight="Bold"
                                               Foreground="{DynamicResource BrushSuccess}"/>
                                    <TextBlock Text="{Binding AddAssetFoundName}"
                                               FontSize="11" Foreground="{DynamicResource BrushSuccess}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0 0 0 4"
                                            IsVisible="{Binding AddIsAssetNotFound}">
                                    <TextBlock Text="✗ Nenalezeno na CoinGecko (krypto). Akcie/ETF? Zadej cenu v USD ručně:"
                                               FontSize="11" Foreground="{DynamicResource BrushDanger}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <!-- Ruční cena (záloha pro akcie / ETF) -->
                                <StackPanel IsVisible="{Binding AddShowManualPrice}" Margin="0 0 0 8">
                                    <TextBox Text="{Binding AddManualPriceText}"
                                             PlaceholderText="Cena v USD, např. 192.50"
                                             Margin="0 4 0 0"/>
                                </StackPanel>
                                <!-- Indikátor ruční ceny (Manual stav) -->
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0 0 0 12"
                                            IsVisible="{Binding AddIsAssetManual}">
                                    <TextBlock Text="✓" FontSize="11" FontWeight="Bold"
                                               Foreground="{DynamicResource BrushSuccess}"/>
                                    <TextBlock Text="{Binding AddAssetFoundName}"
                                               FontSize="11" Foreground="{DynamicResource BrushSuccess}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0 0 0 12"
                                            IsVisible="{Binding AddIsAssetError}">
                                    <TextBlock Text="⚠ " FontSize="11" Foreground="{DynamicResource BrushDanger}"/>
                                    <TextBlock Text="{Binding AddAssetFoundName}"
                                               FontSize="11" Foreground="{DynamicResource BrushDanger}"/>
                                </StackPanel>
                                <Border Height="12" IsVisible="{Binding AddIsAssetNone}"/>

                                <!-- ── Počáteční zůstatek ─── -->
                                <Grid ColumnDefinitions="*,8,Auto" Margin="0 0 0 5">
                                    <TextBlock Grid.Column="0"
                                               Text="Počáteční zůstatek"
                                               FontSize="12" FontWeight="Medium"
                                               Foreground="{DynamicResource BrushTextSecondary}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="0"
                                               Text="(auto z výpisu)"
                                               FontSize="10"
                                               Foreground="{DynamicResource BrushTextSecondary}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding AddHasCsv}"/>
                                </Grid>
                                <TextBox Text="{Binding AddBalanceText}"
                                         PlaceholderText="0 — nebo importuj výpis níže"
                                         Margin="0 0 0 8"/>

                                <!-- ── Import výpisu při vytváření ─── -->
                                <Grid ColumnDefinitions="*,8,Auto" Margin="0 0 0 16">
                                    <Border Grid.Column="0"
                                            CornerRadius="6" Padding="10 7"
                                            Background="{DynamicResource BrushSurfaceAlt}"
                                            BorderBrush="{DynamicResource BrushBorder}"
                                            BorderThickness="1"
                                            IsVisible="{Binding AddHasCsv}">
                                        <TextBlock Text="{Binding AddCsvLabel}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource BrushSuccess}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                    <Button Grid.Column="2"
                                            Classes="ghost"
                                            Click="AttachCsv_Click"
                                            Padding="12 7" CornerRadius="6"
                                            ToolTip.Tip="Vybrat CSV výpis — balance + transakce se importují automaticky">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="📎" FontSize="12"/>
                                            <TextBlock Text="Přiložit výpis" FontSize="12"
                                                       IsVisible="{Binding !AddHasCsv}"
                                                       Foreground="{DynamicResource BrushTextSecondary}"/>
                                            <TextBlock Text="Změnit výpis" FontSize="12"
                                                       IsVisible="{Binding AddHasCsv}"
                                                       Foreground="{DynamicResource BrushTextSecondary}"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel><!-- end AddShowAssetSection -->

                            <!-- ── Adresa peněženky (jen krypto, volitelné) ─── -->
                            <StackPanel IsVisible="{Binding AddIsTypeCrypto}" Spacing="4" Margin="0 0 0 12">
                                <TextBlock Text="Adresa nebo xpub peněženky (volitelné)"
                                           FontSize="12" FontWeight="Medium"
                                           Foreground="{DynamicResource BrushTextSecondary}"/>
                                <TextBox Text="{Binding AddWalletAddress}"
                                         PlaceholderText="bc1q… / xpub… / zpub… / 0x…"
                                         FontSize="12"/>
                                <TextBlock FontSize="10" Foreground="{DynamicResource BrushTextSecondary}"
                                           Opacity="0.6" TextWrapping="Wrap"
                                           Text="Pro HD peněženky (každá transakce jiná adresa) zadej xpub / zpub z nastavení peněženky."
                                           IsVisible="{Binding AddWalletAddress, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                <Grid ColumnDefinitions="Auto,*" Margin="0 4 0 0"
                                      IsVisible="{Binding AddWalletAddress, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <TextBlock Grid.Column="0" Text="Síť:"
                                               FontSize="12" FontWeight="Medium"
                                               Foreground="{DynamicResource BrushTextSecondary}"
                                               VerticalAlignment="Center" Margin="0 0 8 0"/>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{x:Static vm:AccountsViewModel.BlockchainNetworkNames}"
                                              SelectedIndex="{Binding AddWalletNetwork}"
                                              HorizontalAlignment="Stretch"
                                              FontSize="12"/>
                                </Grid>
                                <TextBlock Text="Po vytvoření účtu bude adresa synchronizována automaticky"
                                           FontSize="10"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           Opacity="0.7"
                                           IsVisible="{Binding AddWalletAddress, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            </StackPanel>

                            <!-- ── Oddělovač ─── -->
                            <Border Height="1" Background="{DynamicResource BrushBorder}" Margin="0 8 0 16"/>

                            <!-- ── Akční tlačítka ─── -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                                <Button Classes="secondary"
                                        Command="{Binding CancelAddAccountCommand}"
                                        Content="Zrušit"
                                        Padding="20 9"/>
                                <Button Classes="primary"
                                        Command="{Binding ConfirmAddAccountCommand}"
                                        IsEnabled="{Binding AddCanConfirm}"
                                        Content="{Binding AddConfirmButtonText}"
                                        Padding="20 9"/>
                            </StackPanel>

                        </StackPanel>
                    </Border>
                </Panel>
            </Panel>

            <!-- ══════════════════════════════════════
                 MODAL — NOVÁ TRANSAKCE
                 Viewport-fixed: mimo ScrollViewer
                 ══════════════════════════════════════ -->
            <Panel Grid.Row="0" Grid.RowSpan="2"
                   IsVisible="{Binding AccountsVM.IsNewTxDialogOpen}">
                <Panel DataContext="{Binding AccountsVM}"
                       x:DataType="vm:AccountsViewModel">

                    <!-- Backdrop -->
                    <Border Background="#B2000000"/>

                    <!-- Dialog card -->
                    <Border Width="720"
                            CornerRadius="14"
                            Background="{DynamicResource BrushSurface}"
                            BorderBrush="{DynamicResource BrushBorder}"
                            BorderThickness="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            BoxShadow="0 12 48 4 #70000000">

                        <Grid RowDefinitions="Auto,*,Auto">

                            <!-- ── HEADER: přepínač + zavřít ──────────────── -->
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto"
                                  Margin="20 18 20 0">

                                <!-- Přepínač Příjem | Transfer | Výdaj -->
                                <Border Grid.Column="0"
                                        CornerRadius="9"
                                        Background="{DynamicResource BrushSurfaceAlt}"
                                        BorderBrush="{DynamicResource BrushBorder}"
                                        BorderThickness="1"
                                        Padding="3"
                                        HorizontalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="0">
                                        <Button Classes="seg" Classes.on="{Binding IsNewTxIn}"
                                                Command="{Binding SetNewTxInCommand}"
                                                Padding="26 7" Content="Příjem"/>
                                        <Button Classes="seg" Classes.on="{Binding IsNewTxTransfer}"
                                                Command="{Binding SetNewTxTransferCommand}"
                                                Padding="26 7" Content="Transfer"/>
                                        <Button Classes="seg" Classes.on="{Binding IsNewTxOut}"
                                                Command="{Binding SetNewTxOutCommand}"
                                                Padding="26 7" Content="Výdaj"/>
                                    </StackPanel>
                                </Border>

                                <!-- Zavřít -->
                                <Button Grid.Column="1"
                                        Classes="ghost"
                                        Command="{Binding CloseNewTxDialogCommand}"
                                        Width="30" Height="30" Padding="0" CornerRadius="8"
                                        Margin="10 0 0 0" VerticalAlignment="Center">
                                    <TextBlock Text="✕" FontSize="13"
                                               Foreground="{DynamicResource BrushTextSecondary}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                            </Grid>

                            <!-- ── OBSAH ───────────────────────────────────── -->
                            <Panel Grid.Row="1" Margin="0 16 0 0" MinHeight="230">

                                <!-- ════════ PŘÍJEM ════════
                                     LEFT : částka + velká zelená →
                                     RIGHT: účet + popisek + datum            -->
                                <Grid IsVisible="{Binding IsNewTxIn}"
                                      ColumnDefinitions="*,1,*">

                                    <!-- LEFT -->
                                    <StackPanel Grid.Column="0"
                                                Margin="28 0 20 0"
                                                VerticalAlignment="Center"
                                                Spacing="14">
                                        <!-- Filled green arrow → -->
                                        <Viewbox Width="130" Height="80"
                                                 HorizontalAlignment="Left">
                                            <Canvas Width="100" Height="62">
                                                <Path Data="M 0,19 L 58,19 L 58,0 L 100,31 L 58,62 L 58,43 L 0,43 Z"
                                                      Fill="#00E57A"/>
                                            </Canvas>
                                        </Viewbox>
                                        <TextBox Text="{Binding NewTxAmount}"
                                                 PlaceholderText="Příchozí částka"
                                                 FontSize="17" FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <!-- Dělicí čára -->
                                    <Border Grid.Column="1"
                                            Background="{DynamicResource BrushBorder}"/>

                                    <!-- RIGHT -->
                                    <StackPanel Grid.Column="2"
                                                Margin="20 16 28 20"
                                                Spacing="8"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Účet"
                                                   FontSize="11" FontWeight="Medium"
                                                   Foreground="{DynamicResource BrushTextSecondary}"/>
                                        <ComboBox ItemsSource="{Binding Accounts}"
                                                  SelectedItem="{Binding NewTxSourceAccount}"
                                                  HorizontalAlignment="Stretch">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate DataType="vm:AccountCardViewModel">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <Border Width="8" Height="8" CornerRadius="4"
                                                                Background="{Binding IconBrush}"
                                                                VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding AccountName}" FontSize="13"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <TextBlock Text="Kategorie"
                                                   FontSize="11" FontWeight="Medium"
                                                   Foreground="{DynamicResource BrushTextSecondary}"/>
                                        <ComboBox ItemsSource="{x:Static vm:AccountsViewModel.PredefinedCategories}"
                                                  SelectedItem="{Binding NewTxCategory}"
                                                  PlaceholderText="Vyberte nebo napište…"
                                                  IsEditable="True"
                                                  HorizontalAlignment="Stretch"
                                                  FontSize="13"/>
                                        <TextBlock Text="Popisek"
                                                   FontSize="11" FontWeight="Medium"
                                                   Foreground="{DynamicResource BrushTextSecondary}"/>
                                        <TextBox Text="{Binding NewTxNote}"
                                                 PlaceholderText="Od koho / popis…"
                                                 FontSize="13"/>
                                        <TextBlock Text="Datum"
                                                   FontSize="11" FontWeight="Medium"
                                                   Foreground="{DynamicResource BrushTextSecondary}"/>
                                        <DatePicker SelectedDate="{Binding NewTxDate}"
                                                    HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                </Grid>

                                <!-- ════════ VÝDAJ ════════
                                     LEFT : účet + popisek + datum
                                     RIGHT: částka + velká červená →           -->
                                <Grid IsVisible="{Binding IsNewTxOut}"
                                      ColumnDefinitions="*,1,*">

                                    <!-- LEFT -->
                                    <StackPanel Grid.Column="0"
                                                Margin="28 16 20 20"
                                                Spacing="8"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Účet"
                                                   FontSize="11" FontWeight="Medium"
                                                   Foreground="{DynamicResource BrushTextSecondary}"/>
                                        <ComboBox ItemsSource="{Binding Accounts}"
                                                  SelectedItem="{Binding NewTxSourceAccount}"
                                                  HorizontalAlignment="Stretch">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate DataType="vm:AccountCardViewModel">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <Border Width="8" Height="8" CornerRadius="4"
                                                                Background="{Binding IconBrush}"
                                                                VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding AccountName}" FontSize="13"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <TextBlock Text="Kategorie"
                                                   FontSize="11" FontWeight="Medium"
                                                   Foreground="{DynamicResource BrushTextSecondary}"/>
                                        <ComboBox ItemsSource="{x:Static vm:AccountsViewModel.PredefinedCategories}"
                                                  SelectedItem="{Binding NewTxCategory}"
                                                  PlaceholderText="Vyberte nebo napište…"
                                                  IsEditable="True"
                                                  HorizontalAlignment="Stretch"
                                                  FontSize="13"/>
                                        <TextBlock Text="Popisek"
                                                   FontSize="11" FontWeight="Medium"
                                                   Foreground="{DynamicResource BrushTextSecondary}"/>
                                        <TextBox Text="{Binding NewTxNote}"
                                                 PlaceholderText="Komu / popis…"
                                                 FontSize="13"/>
                                        <TextBlock Text="Datum"
                                                   FontSize="11" FontWeight="Medium"
                                                   Foreground="{DynamicResource BrushTextSecondary}"/>
                                        <DatePicker SelectedDate="{Binding NewTxDate}"
                                                    HorizontalAlignment="Stretch"/>
                                    </StackPanel>

                                    <!-- Dělicí čára -->
                                    <Border Grid.Column="1"
                                            Background="{DynamicResource BrushBorder}"/>

                                    <!-- RIGHT -->
                                    <StackPanel Grid.Column="2"
                                                Margin="20 0 28 0"
                                                VerticalAlignment="Center"
                                                Spacing="14">
                                        <!-- Filled red arrow → -->
                                        <Viewbox Width="130" Height="80"
                                                 HorizontalAlignment="Right">
                                            <Canvas Width="100" Height="62">
                                                <Path Data="M 0,19 L 58,19 L 58,0 L 100,31 L 58,62 L 58,43 L 0,43 Z"
                                                      Fill="#FF3355"/>
                                            </Canvas>
                                        </Viewbox>
                                        <TextBox Text="{Binding NewTxAmount}"
                                                 PlaceholderText="Odchozí částka"
                                                 FontSize="17" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>

                                <!-- ════════ TRANSFER ════════
                                     ROW 0: oba účty vedle sebe s šipkou →
                                     ROW 1: oddělovač
                                     ROW 2: částka + poplatek | datum + popisek  -->
                                <Grid IsVisible="{Binding IsNewTxTransfer}"
                                      RowDefinitions="Auto,1,*">

                                    <!-- ROW 0: Z účtu → Na účet -->
                                    <Grid Grid.Row="0"
                                          ColumnDefinitions="*,Auto,*"
                                          Margin="24 16 24 14">

                                        <!-- Z účtu -->
                                        <StackPanel Grid.Column="0" Spacing="5">
                                            <TextBlock Text="Z účtu"
                                                       FontSize="11" FontWeight="Medium"
                                                       Foreground="{DynamicResource BrushTextSecondary}"/>
                                            <ComboBox ItemsSource="{Binding Accounts}"
                                                      SelectedItem="{Binding NewTxSourceAccount}"
                                                      HorizontalAlignment="Stretch">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate DataType="vm:AccountCardViewModel">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <Border Width="8" Height="8" CornerRadius="4"
                                                                    Background="{Binding IconBrush}"
                                                                    VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding AccountName}" FontSize="13"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <TextBlock Text="{Binding NewTxSourceBalance}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource BrushTextSecondary}"/>
                                        </StackPanel>

                                        <!-- Šipka → -->
                                        <TextBlock Grid.Column="1"
                                                   Text="→"
                                                   FontSize="28" FontWeight="Bold"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource BrushAccent}"
                                                   Margin="18 0"/>

                                        <!-- Na účet -->
                                        <StackPanel Grid.Column="2" Spacing="5">
                                            <TextBlock Text="Na účet"
                                                       FontSize="11" FontWeight="Medium"
                                                       Foreground="{DynamicResource BrushTextSecondary}"/>
                                            <ComboBox ItemsSource="{Binding Accounts}"
                                                      SelectedItem="{Binding NewTxTransferTarget}"
                                                      PlaceholderText="Vyberte účet…"
                                                      HorizontalAlignment="Stretch">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate DataType="vm:AccountCardViewModel">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <Border Width="8" Height="8" CornerRadius="4"
                                                                    Background="{Binding IconBrush}"
                                                                    VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding AccountName}" FontSize="13"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <TextBlock Text="{Binding NewTxTargetBalance}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource BrushTextSecondary}"
                                                       IsVisible="{Binding NewTxTransferTarget,
                                                           Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- ROW 1: oddělovač -->
                                    <Border Grid.Row="1"
                                            Background="{DynamicResource BrushBorder}"
                                            Margin="24 0"/>

                                    <!-- ROW 2: Částka + Poplatek | Datum + Popisek -->
                                    <Grid Grid.Row="2"
                                          ColumnDefinitions="*,*"
                                          Margin="24 14 24 16">

                                        <!-- Částka + Poplatek -->
                                        <StackPanel Grid.Column="0" Spacing="7" Margin="0 0 14 0">
                                            <TextBlock Text="Částka"
                                                       FontSize="11" FontWeight="Medium"
                                                       Foreground="{DynamicResource BrushTextSecondary}"/>
                                            <TextBox Text="{Binding NewTxAmount}"
                                                     PlaceholderText="0,00"
                                                     FontSize="16" FontWeight="SemiBold"/>
                                            <TextBlock Text="Poplatek"
                                                       FontSize="11" FontWeight="Medium"
                                                       Foreground="{DynamicResource BrushTextSecondary}"/>
                                            <TextBox Text="{Binding NewTxFee}"
                                                     PlaceholderText="0,00"
                                                     FontSize="13"/>
                                        </StackPanel>

                                        <!-- Datum + Popisek -->
                                        <StackPanel Grid.Column="1" Spacing="7" Margin="14 0 0 0">
                                            <TextBlock Text="Datum"
                                                       FontSize="11" FontWeight="Medium"
                                                       Foreground="{DynamicResource BrushTextSecondary}"/>
                                            <DatePicker SelectedDate="{Binding NewTxDate}"
                                                        HorizontalAlignment="Stretch"/>
                                            <TextBlock Text="Kategorie"
                                                       FontSize="11" FontWeight="Medium"
                                                       Foreground="{DynamicResource BrushTextSecondary}"/>
                                            <ComboBox ItemsSource="{x:Static vm:AccountsViewModel.PredefinedCategories}"
                                                      SelectedItem="{Binding NewTxCategory}"
                                                      PlaceholderText="Vyberte nebo napište…"
                                                      IsEditable="True"
                                                      HorizontalAlignment="Stretch"
                                                      FontSize="13"/>
                                            <TextBlock Text="Popisek"
                                                       FontSize="11" FontWeight="Medium"
                                                       Foreground="{DynamicResource BrushTextSecondary}"/>
                                            <TextBox Text="{Binding NewTxNote}"
                                                     PlaceholderText="Poznámka…"
                                                     FontSize="13"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>

                            </Panel><!-- /obsah -->

                            <!-- ── FOOTER: tlačítka ───────────────────────── -->
                            <Border Grid.Row="2"
                                    BorderBrush="{DynamicResource BrushBorder}"
                                    BorderThickness="0 1 0 0"
                                    Padding="20 14">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <Button Grid.Column="0"
                                            Classes="primary"
                                            Command="{Binding SaveNewTransactionCommand}"
                                            IsEnabled="{Binding !IsNewTxSaving}"
                                            Content="Přidat"
                                            Padding="22 9"/>
                                    <Button Grid.Column="2"
                                            Classes="secondary"
                                            Command="{Binding CloseNewTxDialogCommand}"
                                            Content="Zrušit"
                                            Padding="22 9"/>
                                </Grid>
                            </Border>

                        </Grid>
                    </Border>
                </Panel>
            </Panel>

            <!-- ══════════════════════════════════════
                 MODAL — DETAIL TRANSAKCE
                 ══════════════════════════════════════ -->
            <Panel Grid.Row="0" Grid.RowSpan="2"
                   IsVisible="{Binding AccountsVM.IsTxDetailOpen}">
                <Panel DataContext="{Binding AccountsVM}"
                       x:DataType="vm:AccountsViewModel">
                    <!-- Backdrop -->
                    <Border Background="#B2000000"/>

                    <!-- Dialog card -->
                    <Border Width="480"
                            CornerRadius="14"
                            Background="{DynamicResource BrushSurface}"
                            BoxShadow="0 8 48 0 #66000000"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Padding="0">
                        <Grid RowDefinitions="Auto,*,Auto">

                            <!-- HEADER: ikona + typ + účet + ✕ -->
                            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto"
                                  Margin="22 18 16 14">
                                <!-- Ikona kruhu -->
                                <Border Grid.Column="0"
                                        Width="42" Height="42" CornerRadius="21"
                                        Background="{DynamicResource BrushSurfaceHover}"
                                        Margin="0 0 14 0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SelectedTxDetail.IconText}"
                                               FontSize="18" FontWeight="Bold"
                                               Foreground="{Binding SelectedTxDetail.IconBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <!-- Typ + datum -->
                                <StackPanel Grid.Column="1" Spacing="2"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TxDetailTypeLabel}"
                                               FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource BrushText}"/>
                                    <TextBlock Text="{Binding TxDetailDate}"
                                               FontSize="12"
                                               Foreground="{DynamicResource BrushTextSecondary}"/>
                                </StackPanel>
                                <!-- Zavřít -->
                                <Button Grid.Column="2"
                                        Classes="ghost"
                                        Command="{Binding CloseTxDetailCommand}"
                                        Width="32" Height="32" Padding="0"
                                        CornerRadius="8"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="✕" FontSize="13"
                                               Foreground="{DynamicResource BrushTextSecondary}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Button>
                            </Grid>

                            <!-- Separator -->
                            <Border Grid.Row="0" Grid.RowSpan="2"
                                    Height="1"
                                    Background="{DynamicResource BrushBorder}"
                                    VerticalAlignment="Bottom"
                                    Margin="0 0 0 0"/>

                            <!-- CONTENT: detail fields -->
                            <ScrollViewer Grid.Row="1" Padding="22 16">
                                <StackPanel Spacing="0">

                                    <!-- Částka (velká) -->
                                    <TextBlock Text="{Binding SelectedTxDetail.Amount}"
                                               FontSize="28" FontWeight="Bold"
                                               Foreground="{Binding SelectedTxDetail.IconBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0 0 0 20"/>

                                    <!-- Grid s poli -->
                                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                          >
                                        <!-- Řádek 1: Účet / Typ -->
                                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2" Margin="0 0 12 14">
                                            <TextBlock Text="Účet"
                                                       FontSize="11" FontWeight="Medium"
                                                       Foreground="{DynamicResource BrushTextSecondary}"/>
                                            <TextBlock Text="{Binding TxDetailAccountName}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrushText}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2" Margin="12 0 0 14">
                                            <TextBlock Text="Typ"
                                                       FontSize="11" FontWeight="Medium"
                                                       Foreground="{DynamicResource BrushTextSecondary}"/>
                                            <TextBlock Text="{Binding TxDetailTypeLabel}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrushText}"/>
                                        </StackPanel>

                                        <!-- Řádek 2: Z účtu / Na účet (jen pro převody) -->
                                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2" Margin="0 0 12 14"
                                                    IsVisible="{Binding SelectedTxDetail.IsTransfer}">
                                            <TextBlock Text="Z účtu"
                                                       FontSize="11" FontWeight="Medium"
                                                       Foreground="{DynamicResource BrushTextSecondary}"/>
                                            <TextBlock Text="{Binding TxDetailFromAccountName}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrushText}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2" Margin="12 0 0 14"
                                                    IsVisible="{Binding SelectedTxDetail.IsTransfer}">
                                            <TextBlock Text="Na účet"
                                                       FontSize="11" FontWeight="Medium"
                                                       Foreground="{DynamicResource BrushTextSecondary}"/>
                                            <TextBlock Text="{Binding TxDetailToAccountName}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrushText}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <!-- Řádek 3: Poplatek / Popis -->
                                        <StackPanel Grid.Row="2" Grid.Column="0" Spacing="2" Margin="0 0 12 14">
                                            <TextBlock Text="Poplatek"
                                                       FontSize="11" FontWeight="Medium"
                                                       Foreground="{DynamicResource BrushTextSecondary}"/>
                                            <TextBlock Text="{Binding TxDetailFee}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrushText}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="2" Grid.Column="1" Spacing="2" Margin="12 0 0 14">
                                            <TextBlock Text="Popis"
                                                       FontSize="11" FontWeight="Medium"
                                                       Foreground="{DynamicResource BrushTextSecondary}"/>
                                            <TextBlock Text="{Binding SelectedTxDetail.Description}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrushText}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <!-- Řádek 4: Kategorie / Poznámka -->
                                        <StackPanel Grid.Row="3" Grid.Column="0" Spacing="2" Margin="0 0 12 4">
                                            <TextBlock Text="Kategorie"
                                                       FontSize="11" FontWeight="Medium"
                                                       Foreground="{DynamicResource BrushTextSecondary}"/>
                                            <TextBlock Text="{Binding TxDetailCategory}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrushText}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="3" Grid.Column="1" Spacing="2" Margin="12 0 0 4">
                                            <TextBlock Text="Poznámka"
                                                       FontSize="11" FontWeight="Medium"
                                                       Foreground="{DynamicResource BrushTextSecondary}"/>
                                            <TextBlock Text="{Binding TxDetailNote}"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource BrushText}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>

                                </StackPanel>
                            </ScrollViewer>

                            <!-- FOOTER -->
                            <Border Grid.Row="2"
                                    BorderBrush="{DynamicResource BrushBorder}"
                                    BorderThickness="0 1 0 0"
                                    Padding="20 12">
                                <Button Classes="secondary"
                                        Command="{Binding CloseTxDetailCommand}"
                                        HorizontalAlignment="Right"
                                        Content="Zavřít"
                                        Padding="20 8"/>
                            </Border>

                        </Grid>
                    </Border>
                </Panel>
            </Panel>

        </Grid>

        <!-- ══════════════════════════════════════════
             SHUTDOWN OVERLAY — zobrazí se při zavírání
             s neuloženými změnami
             ══════════════════════════════════════════ -->
        <Panel Grid.Column="0" Grid.ColumnSpan="2"
               IsVisible="{Binding IsShuttingDown}"
               ZIndex="200">
            <!-- Backdrop -->
            <Border Background="#CC000000"/>

            <!-- Card -->
            <Border Width="400"
                    CornerRadius="14"
                    Background="{DynamicResource BrushSurface}"
                    BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="1"
                    Padding="32 28"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BoxShadow="0 12 48 4 #70000000">
                <StackPanel Spacing="16">

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="💾" FontSize="22" VerticalAlignment="Center"/>
                        <TextBlock Text="Ukládám změny"
                                   FontSize="17" FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushTextPrimary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <ProgressBar IsIndeterminate="{Binding IsSyncingOnShutdown}"
                                 Height="3"
                                 CornerRadius="2"
                                 Foreground="{DynamicResource BrushAccent}"
                                 Background="{DynamicResource BrushSurfaceAlt}"/>

                    <TextBlock Text="{Binding ShutdownStatus}"
                               FontSize="13"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               TextWrapping="Wrap"/>

                </StackPanel>
            </Border>
        </Panel>

    </Grid>
</Window>
