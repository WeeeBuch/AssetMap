<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:components="using:AssetMap.Avalonia.Views.Components"
             x:Class="AssetMap.Avalonia.Views.Components.StatBadge"
             x:DataType="components:StatBadge">

    <Panel>
        <!-- Pozitivní — zelená -->
        <Border Background="#204EC994" CornerRadius="4" Padding="7 3"
                IsVisible="{Binding IsPositive}">
            <TextBlock Text="{Binding Value}"
                       Foreground="{DynamicResource BrushSuccess}"
                       FontSize="12" FontWeight="SemiBold"/>
        </Border>

        <!-- Negativní — červená -->
        <Border Background="#20F14C4C" CornerRadius="4" Padding="7 3"
                IsVisible="{Binding IsNegative}">
            <TextBlock Text="{Binding Value}"
                       Foreground="{DynamicResource BrushDanger}"
                       FontSize="12" FontWeight="SemiBold"/>
        </Border>

        <!-- Neutrální — šedá (výchozí) -->
        <Border Background="{DynamicResource BrushSurfaceAlt}"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="1"
                CornerRadius="4" Padding="7 3">
            <Border.IsVisible>
                <MultiBinding Converter="{x:Static BoolConverters.And}">
                    <Binding Path="!IsPositive"/>
                    <Binding Path="!IsNegative"/>
                </MultiBinding>
            </Border.IsVisible>
            <TextBlock Text="{Binding Value}"
                       Foreground="{DynamicResource BrushTextSecondary}"
                       FontSize="12" FontWeight="SemiBold"/>
        </Border>
    </Panel>
</UserControl>
