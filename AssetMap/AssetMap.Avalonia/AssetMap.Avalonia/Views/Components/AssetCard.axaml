<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:components="using:AssetMap.Avalonia.Views.Components"
             x:Class="AssetMap.Avalonia.Views.Components.AssetCard"
             x:DataType="components:AssetCard">

    <Border Classes="card">
        <StackPanel Spacing="6">

            <!-- Název s barevnou tečkou -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Border Width="10" Height="10" CornerRadius="5"
                        Background="{Binding DotBrush}"
                        VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Title}"
                           Foreground="{DynamicResource BrushTextSecondary}"
                           FontSize="12"/>
            </StackPanel>

            <!-- Hodnota -->
            <TextBlock Text="{Binding TotalValue}"
                       Foreground="{DynamicResource BrushTextPrimary}"
                       FontSize="22" FontWeight="Bold"/>

            <!-- Množství -->
            <TextBlock Text="{Binding Quantity}"
                       Foreground="{DynamicResource BrushTextSecondary}"
                       FontSize="12"/>

            <!-- Změna — zelená nebo červená -->
            <Border Background="#204EC994" CornerRadius="4" Padding="6 2"
                    HorizontalAlignment="Left"
                    IsVisible="{Binding IsPositive}">
                <TextBlock Text="{Binding Change}"
                           Foreground="{DynamicResource BrushSuccess}"
                           FontSize="12" FontWeight="SemiBold"/>
            </Border>

            <Border Background="#20F14C4C" CornerRadius="4" Padding="6 2"
                    HorizontalAlignment="Left"
                    IsVisible="{Binding !IsPositive}">
                <TextBlock Text="{Binding Change}"
                           Foreground="{DynamicResource BrushDanger}"
                           FontSize="12" FontWeight="SemiBold"/>
            </Border>

        </StackPanel>
    </Border>
</UserControl>
