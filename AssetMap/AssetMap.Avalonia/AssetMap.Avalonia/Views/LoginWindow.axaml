<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AssetMap.Avalonia.ViewModels"
        x:Class="AssetMap.Avalonia.Views.LoginWindow"
        x:DataType="vm:LoginViewModel"
        Title="AssetMap"
        Width="440" Height="520"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BrushBackground}">

    <Grid>
        <!-- Jemný gradient pozadí -->
        <Border>
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="#FF1E1E1E" Offset="0"/>
                    <GradientStop Color="#FF22223A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Přihlašovací karta -->
        <Border Width="360"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Background="{DynamicResource BrushSurface}"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="1"
                CornerRadius="10"
                BoxShadow="0 8 40 0 #40000000"
                Padding="40 44">
            <StackPanel Spacing="0">

                <!-- Logo + název -->
                <StackPanel HorizontalAlignment="Center" Spacing="10" Margin="0 0 0 32">
                    <Border Width="56" Height="56"
                            CornerRadius="14"
                            HorizontalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                <GradientStop Color="#FF0078D4" Offset="0"/>
                                <GradientStop Color="#FF00B4D8" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="A"
                                   FontSize="26" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="AssetMap"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource BrushTextPrimary}"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Správa vašeho portfolia"
                               FontSize="13"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Formulář -->
                <StackPanel Spacing="12">
                    <StackPanel Spacing="5">
                        <TextBlock Text="Uživatelské jméno"
                                   FontSize="12" FontWeight="Medium"
                                   Foreground="{DynamicResource BrushTextSecondary}"/>
                        <TextBox Text="{Binding Username}"
                                 PlaceholderText="Zadejte uživatelské jméno"/>
                    </StackPanel>

                    <StackPanel Spacing="5">
                        <TextBlock Text="Heslo"
                                   FontSize="12" FontWeight="Medium"
                                   Foreground="{DynamicResource BrushTextSecondary}"/>
                        <TextBox Text="{Binding Password}"
                                 PasswordChar="•"
                                 PlaceholderText="Zadejte heslo"/>
                    </StackPanel>
                </StackPanel>

                <!-- Chybová hláška -->
                <Border Margin="0 12 0 0"
                        Background="#20F14C4C"
                        BorderBrush="{DynamicResource BrushDanger}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10 8"
                        IsVisible="{Binding ErrorMessage,
                            Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{DynamicResource BrushDanger}"
                               FontSize="12"/>
                </Border>

                <!-- Tlačítko přihlásit -->
                <Button Command="{Binding LoginCommand}"
                        Margin="0 20 0 0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Padding="0 12"
                        FontSize="14" FontWeight="SemiBold">
                    <Panel>
                        <TextBlock Text="Přihlásit se"
                                   IsVisible="{Binding !IsBusy}"/>
                        <TextBlock Text="Přihlašování…"
                                   IsVisible="{Binding IsBusy}"/>
                    </Panel>
                </Button>

                <!-- Footer -->
                <TextBlock Text="AssetMap v0.1 · self-hosted"
                           FontSize="11"
                           Foreground="{DynamicResource BrushTextSecondary}"
                           HorizontalAlignment="Center"
                           Margin="0 24 0 0"
                           Opacity="0.5"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>
