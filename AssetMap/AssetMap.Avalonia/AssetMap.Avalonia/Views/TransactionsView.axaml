<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AssetMap.Avalonia.ViewModels"
             x:Class="AssetMap.Avalonia.Views.TransactionsView"
             x:DataType="vm:TransactionsViewModel">
    <Design.DataContext>
        <vm:TransactionsViewModel/>
    </Design.DataContext>

    <StackPanel Spacing="16">

        <!-- ══════════ FILTR + STATS ══════════ -->
        <Border Classes="card" Padding="16 14">
            <Grid ColumnDefinitions="Auto,12,Auto,*,Auto,12,Auto" VerticalAlignment="Center">

                <!-- Výběr účtu -->
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding AccountOptions}"
                          SelectedIndex="{Binding SelectedAccountIndex}"
                          MinWidth="180"
                          VerticalAlignment="Center"/>

                <!-- Typ transakce -->
                <Border Grid.Column="2"
                        CornerRadius="7"
                        Background="{DynamicResource BrushSurfaceAlt}"
                        BorderBrush="{DynamicResource BrushBorder}"
                        BorderThickness="1" Padding="2"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="0">
                        <Button Classes="seg" Classes.on="{Binding IsTypeAll}"
                                Command="{Binding FilterAllCommand}"
                                Content="Vše"/>
                        <Button Classes="seg" Classes.on="{Binding IsTypeCredit}"
                                Command="{Binding FilterCreditCommand}"
                                Content="↓ Příchozí"/>
                        <Button Classes="seg" Classes.on="{Binding IsTypeDebit}"
                                Command="{Binding FilterDebitCommand}"
                                Content="↑ Odchozí"/>
                    </StackPanel>
                </Border>

                <!-- Statistiky -->
                <StackPanel Grid.Column="4"
                            Orientation="Horizontal"
                            Spacing="16"
                            VerticalAlignment="Center">

                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock FontSize="12"
                                   Foreground="{DynamicResource BrushTextSecondary}"
                                   VerticalAlignment="Center">
                            <Run Text="{Binding Count}"/>
                            <Run Text=" transakcí"/>
                        </TextBlock>
                    </StackPanel>

                    <Border Width="1" Background="{DynamicResource BrushBorder}" Margin="0 2"/>

                    <TextBlock Text="{Binding TotalIn}"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource BrushSuccess}"
                               VerticalAlignment="Center"/>

                    <TextBlock Text="{Binding TotalOut}"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource BrushDanger}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Tlačítko přidat -->
                <Button Grid.Column="6"
                        Classes="primary"
                        Command="{Binding OpenAddTransactionCommand}"
                        Content="+ Přidat"
                        Padding="14 7"
                        VerticalAlignment="Center"/>

            </Grid>
        </Border>

        <!-- ══════════ SEZNAM TRANSAKCÍ ══════════ -->
        <Border Classes="card" Padding="0">

            <!-- Hlavička tabulky -->
            <StackPanel>
                <Grid ColumnDefinitions="48,12,48,12,*,Auto"
                      Margin="16 10 16 6">
                    <TextBlock Grid.Column="4"
                               Text="POPIS / ÚČET"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               Opacity="0.7"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="5"
                               Text="ČÁSTKA"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               Opacity="0.7"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </Grid>

                <Border Height="1" Background="{DynamicResource BrushBorder}"
                        Margin="0 0 0 0"/>

                <!-- Prázdný stav -->
                <TextBlock Text="Žádné transakce"
                           FontSize="13"
                           Foreground="{DynamicResource BrushTextSecondary}"
                           HorizontalAlignment="Center"
                           Margin="0 32"
                           IsVisible="{Binding !Filtered.Count}"/>

                <!-- Řádky transakcí -->
                <ItemsControl ItemsSource="{Binding Filtered}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:TxRowItem">
                            <Grid ColumnDefinitions="48,12,48,12,*,Auto,6,Auto"
                                  Margin="16 9 16 9">

                                <!-- Ikona typu (příchozí/odchozí) -->
                                <Border Grid.Column="0"
                                        Width="36" Height="36" CornerRadius="18"
                                        Background="{Binding IconBrush}"
                                        HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding IconText}"
                                               FontSize="14" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <!-- Ikona účtu -->
                                <Border Grid.Column="2"
                                        Width="36" Height="36" CornerRadius="9"
                                        Background="{Binding AccountBrush}"
                                        HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding AccountLetter}"
                                               FontSize="13" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <!-- Popis + účet + datum -->
                                <StackPanel Grid.Column="4"
                                            Spacing="3"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Description}"
                                               FontSize="13"
                                               Foreground="{DynamicResource BrushTextPrimary}"/>
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <TextBlock Text="{Binding AccountName}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource BrushTextSecondary}"/>
                                        <TextBlock Text="·"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource BrushTextSecondary}"
                                                   Opacity="0.5"/>
                                        <TextBlock Text="{Binding Date}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource BrushTextSecondary}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Částka -->
                                <Panel Grid.Column="5" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Amount}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource BrushSuccess}"
                                               IsVisible="{Binding IsCredit}"/>
                                    <TextBlock Text="{Binding Amount}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource BrushDanger}"
                                               IsVisible="{Binding !IsCredit}"/>
                                </Panel>

                                <!-- Detail tlačítko -->
                                <Button Grid.Column="7"
                                        Classes="ghost"
                                        Command="{Binding $parent[ItemsControl].((vm:TransactionsViewModel)DataContext).OpenTxDetailCommand}"
                                        CommandParameter="{Binding}"
                                        Width="28" Height="28" Padding="0" CornerRadius="6"
                                        VerticalAlignment="Center"
                                        ToolTip.Tip="Detail transakce">
                                    <TextBlock Text="ℹ" FontSize="12"
                                               Foreground="{DynamicResource BrushTextSecondary}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Button>

                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                    <!-- Oddělovač mezi řádky -->
                    <ItemsControl.ItemContainerTheme>
                        <ControlTheme TargetType="ContentPresenter">
                            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
                            <Setter Property="BorderThickness" Value="0 0 0 1"/>
                        </ControlTheme>
                    </ItemsControl.ItemContainerTheme>

                </ItemsControl>
            </StackPanel>

        </Border>

    </StackPanel>
</UserControl>
