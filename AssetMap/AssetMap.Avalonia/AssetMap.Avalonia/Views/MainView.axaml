<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AssetMap.Avalonia.ViewModels"
             xmlns:comp="using:AssetMap.Avalonia.Views.Components"
             x:Class="AssetMap.Avalonia.Views.MainView"
             x:DataType="vm:MainViewModel">
    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>

    <StackPanel Spacing="20">

        <!-- ══════════ HERO ══════════ -->
        <Border Classes="card">
            <Grid ColumnDefinitions="Auto,24,*" RowDefinitions="Auto,16,Auto">

                <!-- Celková hodnota + změna -->
                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6" VerticalAlignment="Top">
                    <TextBlock Text="Celková hodnota portfolia"
                               FontSize="13"
                               Foreground="{DynamicResource BrushTextSecondary}"/>

                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding DashboardTotal}"
                                   FontSize="36" FontWeight="Bold"
                                   Foreground="{DynamicResource BrushTextPrimary}"/>
                        <TextBlock Text="{Binding AccountsVM.DisplayCurrency}"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushTextSecondary}"
                                   VerticalAlignment="Bottom" Margin="0 0 0 6"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Background="#204EC994" CornerRadius="4" Padding="8 3"
                                IsVisible="{Binding DashboardPositive}">
                            <TextBlock Text="{Binding DashboardChange}"
                                       Foreground="{DynamicResource BrushSuccess}"
                                       FontSize="12" FontWeight="SemiBold"/>
                        </Border>
                        <Border Background="#25FF3355" CornerRadius="4" Padding="8 3"
                                IsVisible="{Binding !DashboardPositive}">
                            <TextBlock Text="{Binding DashboardChange}"
                                       Foreground="{DynamicResource BrushDanger}"
                                       FontSize="12" FontWeight="SemiBold"/>
                        </Border>
                        <TextBlock Text="za vybrané období"
                                   Foreground="{DynamicResource BrushTextSecondary}"
                                   FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Period switcher — sdílí stav s AccountsVM -->
                <Border Grid.Row="2" Grid.Column="0"
                        CornerRadius="7"
                        Background="{DynamicResource BrushSurfaceAlt}"
                        BorderBrush="{DynamicResource BrushBorder}"
                        BorderThickness="1" Padding="2"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="0">
                        <Button Classes="seg" Classes.on="{Binding AccountsVM.IsPeriodD1}"
                                Command="{Binding AccountsVM.SetPeriodD1Command}" Content="24h"/>
                        <Button Classes="seg" Classes.on="{Binding AccountsVM.IsPeriodD7}"
                                Command="{Binding AccountsVM.SetPeriodD7Command}" Content="7 dní"/>
                        <Button Classes="seg" Classes.on="{Binding AccountsVM.IsPeriodM1}"
                                Command="{Binding AccountsVM.SetPeriodM1Command}" Content="1 měs."/>
                        <Button Classes="seg" Classes.on="{Binding AccountsVM.IsPeriodM3}"
                                Command="{Binding AccountsVM.SetPeriodM3Command}" Content="3 měs."/>
                        <Button Classes="seg" Classes.on="{Binding AccountsVM.IsPeriodY1}"
                                Command="{Binding AccountsVM.SetPeriodY1Command}" Content="1 rok"/>
                    </StackPanel>
                </Border>

                <!-- Chart vývoje celkového portfolia -->
                <comp:SimpleLineChart Grid.Row="0" Grid.RowSpan="3" Grid.Column="2"
                                      Height="160"
                                      BalanceHistory="{Binding AccountsVM.TotalHistory}"/>

            </Grid>
        </Border>

        <!-- ══════════ ÚČTY + TRANSAKCE ══════════ -->
        <Grid ColumnDefinitions="*,16,*">

            <!-- Účty -->
            <Border Grid.Column="0" Classes="card">
                <StackPanel Spacing="4">
                    <Grid ColumnDefinitions="*,Auto" Margin="0 0 0 12">
                        <TextBlock Text="Účty"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushTextPrimary}"/>
                        <Button Grid.Column="1" Classes="ghost" Padding="6 3" FontSize="12">Vše →</Button>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding AccountsVM.Accounts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:AccountCardViewModel">
                                <Grid ColumnDefinitions="36,12,*,Auto" Margin="0 7">

                                    <Border Grid.Column="0"
                                            Width="36" Height="36" CornerRadius="9"
                                            Background="{Binding IconBrush}">
                                        <TextBlock Text="{Binding IconLetter}"
                                                   FontSize="14" FontWeight="Bold" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding AccountName}" FontSize="13"
                                                   Foreground="{DynamicResource BrushTextPrimary}"/>
                                        <TextBlock Text="{Binding Institution}" FontSize="11"
                                                   Foreground="{DynamicResource BrushTextSecondary}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" Spacing="1"
                                                HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding BaseAmount}" FontSize="13" FontWeight="Medium"
                                                       Foreground="{DynamicResource BrushTextPrimary}"/>
                                            <TextBlock Text="{Binding BaseCurrency}" FontSize="11"
                                                       Foreground="{DynamicResource BrushTextSecondary}"
                                                       VerticalAlignment="Bottom" Margin="0 0 0 1"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding ChangeText}" FontSize="11"
                                                   HorizontalAlignment="Right"
                                                   Foreground="{DynamicResource BrushSuccess}"
                                                   IsVisible="{Binding ChangePositive}"/>
                                        <TextBlock Text="{Binding ChangeText}" FontSize="11"
                                                   HorizontalAlignment="Right"
                                                   Foreground="{DynamicResource BrushDanger}"
                                                   IsVisible="{Binding !ChangePositive}"/>
                                    </StackPanel>

                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Transakce -->
            <Border Grid.Column="2" Classes="card">
                <StackPanel Spacing="0">
                    <Grid ColumnDefinitions="*,Auto" Margin="0 0 0 12">
                        <TextBlock Text="Poslední transakce"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushTextPrimary}"/>
                        <Button Grid.Column="1" Classes="ghost" Padding="6 3" FontSize="12">Vše →</Button>
                    </Grid>

                    <Border Classes="separator" Margin="0 0 0 4"/>

                    <ItemsControl ItemsSource="{Binding DashboardRecentTxs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:TransactionDisplayItem">
                                <Grid ColumnDefinitions="36,12,*,Auto" Margin="0 7">

                                    <Border Grid.Column="0"
                                            Width="36" Height="36" CornerRadius="9"
                                            Background="{Binding IconBrush}">
                                        <TextBlock Text="{Binding IconText}"
                                                   FontSize="13" FontWeight="Bold" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Description}" FontSize="13"
                                                   Foreground="{DynamicResource BrushTextPrimary}"/>
                                        <TextBlock Text="{Binding Date}" FontSize="11"
                                                   Foreground="{DynamicResource BrushTextSecondary}"/>
                                    </StackPanel>

                                    <Panel Grid.Column="3" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Amount}" FontSize="13" FontWeight="Medium"
                                                   Foreground="{DynamicResource BrushSuccess}"
                                                   IsVisible="{Binding IsCredit}"/>
                                        <TextBlock Text="{Binding Amount}" FontSize="13" FontWeight="Medium"
                                                   Foreground="{DynamicResource BrushDanger}"
                                                   IsVisible="{Binding !IsCredit}"/>
                                    </Panel>

                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </Border>

        </Grid>

    </StackPanel>
</UserControl>
