<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AssetMap.Avalonia.ViewModels"
             xmlns:c="using:AssetMap.Avalonia.Views.Components"
             x:Class="AssetMap.Avalonia.Views.MainView"
             x:DataType="vm:MainViewModel">
    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>

    <StackPanel Spacing="20">

        <!-- ══════════ HERO ══════════ -->
        <Border Classes="card">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="6">
                    <TextBlock Text="Celková hodnota portfolia"
                               FontSize="13"
                               Foreground="{DynamicResource BrushTextSecondary}"/>
                    <TextBlock Text="$142 350,40"
                               FontSize="38" FontWeight="Bold"
                               Foreground="{DynamicResource BrushTextPrimary}"/>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Background="#204EC994" CornerRadius="4" Padding="8 3">
                            <TextBlock Text="▲ +$3 240,00  +2,32%"
                                       Foreground="{DynamicResource BrushSuccess}"
                                       FontSize="13" FontWeight="SemiBold"/>
                        </Border>
                        <TextBlock Text="dnes"
                                   Foreground="{DynamicResource BrushTextSecondary}"
                                   FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Mini sparkline -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal" Spacing="4"
                            VerticalAlignment="Bottom" Margin="0 0 0 4">
                    <Border Width="8" Height="18" CornerRadius="2" Background="{DynamicResource BrushAccent}" Opacity="0.35"/>
                    <Border Width="8" Height="28" CornerRadius="2" Background="{DynamicResource BrushAccent}" Opacity="0.45"/>
                    <Border Width="8" Height="22" CornerRadius="2" Background="{DynamicResource BrushAccent}" Opacity="0.50"/>
                    <Border Width="8" Height="38" CornerRadius="2" Background="{DynamicResource BrushAccent}" Opacity="0.60"/>
                    <Border Width="8" Height="30" CornerRadius="2" Background="{DynamicResource BrushAccent}" Opacity="0.70"/>
                    <Border Width="8" Height="46" CornerRadius="2" Background="{DynamicResource BrushAccent}" Opacity="0.82"/>
                    <Border Width="8" Height="40" CornerRadius="2" Background="{DynamicResource BrushAccent}" Opacity="0.90"/>
                    <Border Width="8" Height="56" CornerRadius="2" Background="{DynamicResource BrushAccent}" Opacity="1.00"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════ ASSET KARTY ══════════ -->
        <Grid ColumnDefinitions="*,16,*,16,*">
            <c:AssetCard Grid.Column="0"
                         Title="Bitcoin" TotalValue="$82 000,00"
                         Quantity="1,05 BTC" Change="▲ +1,2%"
                         IsPositive="True">
                <c:AssetCard.DotBrush>
                    <SolidColorBrush Color="#F7931A"/>
                </c:AssetCard.DotBrush>
            </c:AssetCard>

            <c:AssetCard Grid.Column="2"
                         Title="Ethereum" TotalValue="$24 500,00"
                         Quantity="10,2 ETH" Change="▲ +3,4%"
                         IsPositive="True">
                <c:AssetCard.DotBrush>
                    <SolidColorBrush Color="#627EEA"/>
                </c:AssetCard.DotBrush>
            </c:AssetCard>

            <c:AssetCard Grid.Column="4"
                         Title="Akcie" TotalValue="$35 850,00"
                         Quantity="3 pozice" Change="▼ -0,8%"
                         IsPositive="False">
                <c:AssetCard.DotBrush>
                    <DynamicResourceExtension ResourceKey="BrushAccent"/>
                </c:AssetCard.DotBrush>
            </c:AssetCard>
        </Grid>

        <!-- ══════════ ÚČTY + TRANSAKCE ══════════ -->
        <Grid ColumnDefinitions="*,16,*">

            <!-- Účty -->
            <Border Grid.Column="0" Classes="card">
                <StackPanel Spacing="4">
                    <Grid ColumnDefinitions="*,Auto" Margin="0 0 0 12">
                        <TextBlock Text="Účty"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushTextPrimary}"/>
                        <Button Grid.Column="1" Classes="ghost" Padding="6 3" FontSize="12">Přidat</Button>
                    </Grid>

                    <c:AccountRow IconText="₿" Name="BTC Peněženka 01"
                                  Subtitle="bc1q…a3f2"
                                  Value="$82 000" SubValue="1,05 BTC"
                                  ShowDivider="True">
                        <c:AccountRow.IconBackground><SolidColorBrush Color="#20F7931A"/></c:AccountRow.IconBackground>
                        <c:AccountRow.IconForeground><SolidColorBrush Color="#F7931A"/></c:AccountRow.IconForeground>
                    </c:AccountRow>

                    <c:AccountRow IconText="Ξ" Name="ETH Peněženka"
                                  Subtitle="0x4a…9c1b"
                                  Value="$24 500" SubValue="10,2 ETH"
                                  ShowDivider="True">
                        <c:AccountRow.IconBackground><SolidColorBrush Color="#20627EEA"/></c:AccountRow.IconBackground>
                        <c:AccountRow.IconForeground><SolidColorBrush Color="#627EEA"/></c:AccountRow.IconForeground>
                    </c:AccountRow>

                    <c:AccountRow IconText="🏦" Name="KB Běžný účet"
                                  Subtitle="Komerční banka"
                                  Value="$35 850" SubValue="CZK 826 500"
                                  ShowDivider="False">
                        <c:AccountRow.IconBackground><SolidColorBrush Color="#200078D4"/></c:AccountRow.IconBackground>
                        <c:AccountRow.IconForeground><SolidColorBrush Color="#0078D4"/></c:AccountRow.IconForeground>
                    </c:AccountRow>
                </StackPanel>
            </Border>

            <!-- Transakce -->
            <Border Grid.Column="2" Classes="card">
                <StackPanel Spacing="14">
                    <Grid ColumnDefinitions="*,Auto" Margin="0 0 0 2">
                        <TextBlock Text="Poslední transakce"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushTextPrimary}"/>
                        <Button Grid.Column="1" Classes="ghost" Padding="6 3" FontSize="12">Vše</Button>
                    </Grid>

                    <c:TransactionRow IconText="▲" Description="Nákup BTC"
                                      Date="06. 06. 2026" Amount="+0,30 BTC"
                                      IsPositive="True">
                        <c:TransactionRow.IconBackground><SolidColorBrush Color="#204EC994"/></c:TransactionRow.IconBackground>
                        <c:TransactionRow.IconForeground><DynamicResourceExtension ResourceKey="BrushSuccess"/></c:TransactionRow.IconForeground>
                    </c:TransactionRow>

                    <c:TransactionRow IconText="↕" Description="Transfer ETH → ETH Wallet"
                                      Date="04. 06. 2026" Amount="5,0 ETH"
                                      IsNeutral="True">
                        <c:TransactionRow.IconBackground><SolidColorBrush Color="#20627EEA"/></c:TransactionRow.IconBackground>
                        <c:TransactionRow.IconForeground><SolidColorBrush Color="#627EEA"/></c:TransactionRow.IconForeground>
                    </c:TransactionRow>

                    <c:TransactionRow IconText="▼" Description="Výdaj — poplatky"
                                      Date="04. 06. 2026" Amount="-0,002 ETH"
                                      IsPositive="False">
                        <c:TransactionRow.IconBackground><SolidColorBrush Color="#20F14C4C"/></c:TransactionRow.IconBackground>
                        <c:TransactionRow.IconForeground><DynamicResourceExtension ResourceKey="BrushDanger"/></c:TransactionRow.IconForeground>
                    </c:TransactionRow>

                    <c:TransactionRow IconText="★" Description="Staking odměna"
                                      Date="01. 06. 2026" Amount="+0,15 ETH"
                                      IsPositive="True">
                        <c:TransactionRow.IconBackground><SolidColorBrush Color="#20CCA700"/></c:TransactionRow.IconBackground>
                        <c:TransactionRow.IconForeground><DynamicResourceExtension ResourceKey="BrushWarning"/></c:TransactionRow.IconForeground>
                    </c:TransactionRow>

                </StackPanel>
            </Border>

        </Grid>

    </StackPanel>
</UserControl>
