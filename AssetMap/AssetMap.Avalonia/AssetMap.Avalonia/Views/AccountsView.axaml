<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AssetMap.Avalonia.ViewModels"
             xmlns:comp="using:AssetMap.Avalonia.Views.Components"
             x:Class="AssetMap.Avalonia.Views.AccountsView"
             x:DataType="vm:AccountsViewModel">
    <Design.DataContext>
        <vm:AccountsViewModel/>
    </Design.DataContext>

<Grid>
<StackPanel Spacing="0">

        <!-- ══════════════════════════════════
             HORIZONTÁLNÍ PRUH KARET
             (drag-to-scroll přes code-behind)
             ══════════════════════════════════ -->
        <ScrollViewer x:Name="CardScroller"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      Padding="0 0 0 4">
            <StackPanel x:Name="CardStrip"
                        Orientation="Horizontal" Spacing="12" Margin="0 4"
                        Cursor="Hand"
                        PointerPressed="CardStrip_PointerPressed"
                        PointerMoved="CardStrip_PointerMoved"
                        PointerReleased="CardStrip_PointerReleased"
                        PointerCaptureLost="CardStrip_PointerCaptureLost">

                <!-- Kartičky účtů -->
                <ItemsControl ItemsSource="{Binding Accounts}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="12"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:AccountCardViewModel">
                            <Button Padding="0" CornerRadius="10" Classes="ghost"
                                    Command="{Binding SelectCommand}"
                                    Width="210">
                                <Panel Width="210" Height="140">

                                    <!-- Základní karta -->
                                    <Border CornerRadius="10"
                                            Background="{DynamicResource BrushSurface}"
                                            BorderBrush="{DynamicResource BrushBorder}"
                                            BorderThickness="1"/>

                                    <!-- Výběr ring (accent border) -->
                                    <Border CornerRadius="10"
                                            BorderBrush="{DynamicResource BrushAccent}"
                                            BorderThickness="1.5"
                                            IsVisible="{Binding IsSelected}"/>

                                    <!-- Obsah -->
                                    <StackPanel Margin="16 14" Spacing="0">

                                        <!-- Hlavička: ikona + název -->
                                        <StackPanel Orientation="Horizontal" Spacing="9" Margin="0 0 0 12">
                                            <Border Width="30" Height="30" CornerRadius="8"
                                                    Background="{Binding IconBrush}">
                                                <TextBlock Text="{Binding IconLetter}"
                                                           FontSize="14" FontWeight="Bold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Spacing="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding AccountName}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource BrushTextPrimary}"/>
                                                <TextBlock Text="{Binding Institution}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource BrushTextSecondary}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Základní částka -->
                                        <StackPanel Spacing="2">
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <TextBlock Text="{Binding BaseAmount}"
                                                           FontSize="18" FontWeight="Bold"
                                                           Foreground="{DynamicResource BrushTextPrimary}"/>
                                                <TextBlock Text="{Binding BaseCurrency}"
                                                           FontSize="12" FontWeight="Medium"
                                                           Foreground="{DynamicResource BrushTextSecondary}"
                                                           VerticalAlignment="Bottom"
                                                           Margin="0 0 0 2"/>
                                            </StackPanel>

                                            <!-- Přepočet na vybranou měnu -->
                                            <StackPanel Orientation="Horizontal" Spacing="4"
                                                        IsVisible="{Binding ConvertedAmount,
                                                            Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                <TextBlock Text="≈" FontSize="11"
                                                           Foreground="{DynamicResource BrushTextSecondary}"/>
                                                <TextBlock Text="{Binding ConvertedAmount}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource BrushTextSecondary}"/>
                                                <TextBlock Text="{Binding ConvertedCurrency}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource BrushTextSecondary}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Změna (%) — dva TextBlocky kvůli compiled binding -->
                                        <Panel Margin="0 8 0 0">
                                            <TextBlock Text="{Binding ChangeText}"
                                                       FontSize="11" FontWeight="Medium"
                                                       Foreground="{DynamicResource BrushSuccess}"
                                                       IsVisible="{Binding ChangePositive}"/>
                                            <TextBlock Text="{Binding ChangeText}"
                                                       FontSize="11" FontWeight="Medium"
                                                       Foreground="{DynamicResource BrushDanger}"
                                                       IsVisible="{Binding !ChangePositive}"/>
                                        </Panel>

                                    </StackPanel>
                                </Panel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Přidat účet -->
                <Button Classes="ghost" Padding="0"
                        Command="{Binding AddAccountCommand}"
                        Width="210" Height="140" CornerRadius="10">
                    <Border Width="210" Height="140"
                            CornerRadius="10"
                            Background="{DynamicResource BrushSurfaceAlt}"
                            BorderBrush="{DynamicResource BrushBorder}"
                            BorderThickness="1">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="8">
                            <TextBlock Text="+"
                                       FontSize="30" FontWeight="Thin"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Přidat účet"
                                       FontSize="12"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Button>

            </StackPanel>
        </ScrollViewer>

        <!-- ══════════════════════════════════
             PŘEHLED (viditelný když nic není vybráno)
             ══════════════════════════════════ -->
        <Grid ColumnDefinitions="300,*" ColumnSpacing="16"
              IsVisible="{Binding !HasSelectedAccount}"
              Margin="0 20 0 0">

            <!-- ── Koláčový graf ──────────────────────────────── -->
            <Border Grid.Column="0" Classes="card">
                <StackPanel Spacing="14">
                    <TextBlock Text="Rozložení portfolia"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource BrushTextPrimary}"/>

                    <comp:PieChart Height="180" Slices="{Binding PieSlices}"/>

                    <!-- Legenda -->
                    <ItemsControl ItemsSource="{Binding PieSlices}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:PieSliceData">
                                <Grid ColumnDefinitions="12,8,*,Auto" Margin="0 4">
                                    <Border Grid.Column="0"
                                            Width="12" Height="12" CornerRadius="6"
                                            Background="{Binding SliceBrush}"
                                            VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Label}"
                                               FontSize="12"
                                               Foreground="{DynamicResource BrushTextPrimary}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding Percent}"
                                               FontSize="11"
                                               Foreground="{DynamicResource BrushTextSecondary}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ── Vývoj portfolia ────────────────────────────── -->
            <Border Grid.Column="1" Classes="card">
                <StackPanel Spacing="14">

                    <!-- Hlavička + toggles -->
                    <Grid ColumnDefinitions="*,Auto,8,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="Vývoj portfolia"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushTextPrimary}"/>

                        <!-- Celkem/Účty toggle -->
                        <Border Grid.Column="1"
                                CornerRadius="7"
                                Background="{DynamicResource BrushSurfaceAlt}"
                                BorderBrush="{DynamicResource BrushBorder}"
                                BorderThickness="1" Padding="2">
                            <StackPanel Orientation="Horizontal" Spacing="0">
                                <Button Classes="seg"
                                        Classes.on="{Binding IsOnTotalChart}"
                                        Command="{Binding SwitchToTotalCommand}"
                                        Content="Celkem"/>
                                <Button Classes="seg"
                                        Classes.on="{Binding IsOnAccountsChart}"
                                        Command="{Binding SwitchToAllLinesCommand}"
                                        Content="Účty"/>
                            </StackPanel>
                        </Border>

                        <!-- Perioda toggle -->
                        <Border Grid.Column="3"
                                CornerRadius="7"
                                Background="{DynamicResource BrushSurfaceAlt}"
                                BorderBrush="{DynamicResource BrushBorder}"
                                BorderThickness="1" Padding="2">
                            <StackPanel Orientation="Horizontal" Spacing="0">
                                <Button Classes="seg" Classes.on="{Binding IsPeriodD1}"
                                        Command="{Binding SetPeriodD1Command}" Content="24h"/>
                                <Button Classes="seg" Classes.on="{Binding IsPeriodD7}"
                                        Command="{Binding SetPeriodD7Command}" Content="7d"/>
                                <Button Classes="seg" Classes.on="{Binding IsPeriodM1}"
                                        Command="{Binding SetPeriodM1Command}" Content="1M"/>
                                <Button Classes="seg" Classes.on="{Binding IsPeriodM3}"
                                        Command="{Binding SetPeriodM3Command}" Content="3M"/>
                                <Button Classes="seg" Classes.on="{Binding IsPeriodY1}"
                                        Command="{Binding SetPeriodY1Command}" Content="1R"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Celkový line graf -->
                    <comp:SimpleLineChart Height="200"
                                          IsVisible="{Binding IsOnTotalChart}"
                                          BalanceHistory="{Binding TotalHistory}"/>

                    <!-- Multi-line graf (% změna od začátku) -->
                    <comp:MultiLineChart Height="200"
                                         IsVisible="{Binding IsOnAccountsChart}"
                                         Lines="{Binding AccountLines}"
                                         YSuffix=" %"/>

                    <!-- Legenda účtů (společná pro oba grafy) -->
                    <ItemsControl ItemsSource="{Binding AccountLines}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="16"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:ChartLine">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Width="10" Height="10" CornerRadius="5"
                                            Background="{Binding LineBrush}"
                                            VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Label}"
                                               FontSize="11"
                                               Foreground="{DynamicResource BrushTextSecondary}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </Border>

        </Grid>

        <!-- ══════════════════════════════════
             DETAIL VYBRANÉHO ÚČTU
             ══════════════════════════════════ -->
        <StackPanel Spacing="16" Margin="0 20 0 0"
                    IsVisible="{Binding HasSelectedAccount}">

            <!-- Hlavička detailu -->
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="{Binding SelectedAccount.AccountName}"
                               FontSize="17" FontWeight="SemiBold"
                               Foreground="{DynamicResource BrushTextPrimary}"/>
                    <TextBlock Text="{Binding SelectedAccount.Institution}"
                               FontSize="12"
                               Foreground="{DynamicResource BrushTextSecondary}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Right"
                            Margin="0 0 16 0">
                    <StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding SelectedAccount.BaseAmount}"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource BrushTextPrimary}"/>
                        <TextBlock Text="{Binding SelectedAccount.BaseCurrency}"
                                   FontSize="13"
                                   Foreground="{DynamicResource BrushTextSecondary}"
                                   VerticalAlignment="Bottom" Margin="0 0 0 2"/>
                    </StackPanel>
                    <TextBlock Text="{Binding SelectedAccount.ChangeText}"
                               FontSize="12" FontWeight="Medium"
                               HorizontalAlignment="Right"
                               Foreground="{DynamicResource BrushTextSecondary}"/>
                </StackPanel>

                <!-- Upravit -->
                <Button Grid.Column="2"
                        Classes="ghost"
                        Command="{Binding OpenEditAccountCommand}"
                        VerticalAlignment="Top"
                        Width="30" Height="30" Padding="0" CornerRadius="8"
                        ToolTip.Tip="Upravit účet"
                        Margin="0 0 4 0">
                    <TextBlock Text="✏" FontSize="13"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

                <!-- Smazat -->
                <Button Grid.Column="3"
                        Classes="ghost"
                        Command="{Binding DeleteAccountCommand}"
                        VerticalAlignment="Top"
                        Width="30" Height="30" Padding="0" CornerRadius="8"
                        ToolTip.Tip="Smazat účet"
                        Margin="0 0 4 0">
                    <TextBlock Text="🗑" FontSize="13"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

                <!-- Zavřít detail -->
                <Button Grid.Column="4"
                        Classes="ghost"
                        Command="{Binding CloseDetailCommand}"
                        VerticalAlignment="Top"
                        Width="30" Height="30" Padding="0" CornerRadius="8"
                        ToolTip.Tip="Zavřít">
                    <TextBlock Text="✕"
                               FontSize="13"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>
            </Grid>

            <!-- Graf vývoje + tečky transakcí -->
            <Border Classes="card" Padding="4 8 4 4">
                <comp:SimpleLineChart Height="230"
                                      BalanceHistory="{Binding SelectedAccount.BalanceHistory}"
                                      DepositIndices="{Binding SelectedAccount.DepositIndices}"
                                      WithdrawalIndices="{Binding SelectedAccount.WithdrawalIndices}"/>
            </Border>

            <!-- Legenda: tečky -->
            <StackPanel Orientation="Horizontal" Spacing="20" Margin="8 0">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Border Width="10" Height="10" CornerRadius="5" Background="#00B3FF"/>
                    <TextBlock Text="Zůstatek" FontSize="11"
                               Foreground="{DynamicResource BrushTextSecondary}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Border Width="10" Height="10" CornerRadius="5" Background="#00E57A"/>
                    <TextBlock Text="Vklad" FontSize="11"
                               Foreground="{DynamicResource BrushTextSecondary}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Border Width="10" Height="10" CornerRadius="5" Background="#FF3355"/>
                    <TextBlock Text="Výběr" FontSize="11"
                               Foreground="{DynamicResource BrushTextSecondary}"/>
                </StackPanel>
            </StackPanel>

            <!-- Seznam transakcí -->
            <Border Classes="card">
                <StackPanel Spacing="0">

                    <!-- Hlavička -->
                    <Grid ColumnDefinitions="*,Auto" Margin="0 0 0 12">
                        <TextBlock Grid.Column="0"
                                   Text="Transakce"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushTextPrimary}"/>
                        <TextBlock Grid.Column="1"
                                   Text="Posledních 60 dní"
                                   FontSize="11"
                                   Foreground="{DynamicResource BrushTextSecondary}"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <Border Classes="separator" Margin="0 0 0 4"/>

                    <!-- Řádky transakcí -->
                    <ItemsControl ItemsSource="{Binding SelectedAccount.Transactions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:TransactionDisplayItem">
                                <Grid ColumnDefinitions="36,12,*,Auto"
                                      Margin="0 7">

                                    <!-- Ikona -->
                                    <Border Grid.Column="0"
                                            Width="36" Height="36" CornerRadius="9"
                                            Background="{Binding IconBrush}">
                                        <TextBlock Text="{Binding IconText}"
                                                   FontSize="13" FontWeight="Bold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Popis + datum -->
                                    <StackPanel Grid.Column="2"
                                                Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource BrushTextPrimary}"/>
                                        <TextBlock Text="{Binding Date}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource BrushTextSecondary}"/>
                                    </StackPanel>

                                    <!-- Částka — dva TextBlocky (compiled binding) -->
                                    <Panel Grid.Column="3" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Amount}"
                                                   FontSize="13" FontWeight="Medium"
                                                   Foreground="{DynamicResource BrushSuccess}"
                                                   IsVisible="{Binding IsCredit}"/>
                                        <TextBlock Text="{Binding Amount}"
                                                   FontSize="13" FontWeight="Medium"
                                                   Foreground="{DynamicResource BrushDanger}"
                                                   IsVisible="{Binding !IsCredit}"/>
                                    </Panel>

                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </Border>

        </StackPanel>
    </StackPanel>


</Grid>
</UserControl>
