<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AssetMap.Avalonia.ViewModels"
             x:Class="AssetMap.Avalonia.Views.SettingsView"
             x:DataType="vm:MainViewModel">
    <Design.DataContext>
        <vm:MainViewModel/>
    </Design.DataContext>

    <StackPanel Spacing="20" MaxWidth="680" HorizontalAlignment="Left">

        <!-- ══════════ PŘIPOJENÍ ══════════ -->
        <Border Classes="card">
            <StackPanel Spacing="16">

                <StackPanel Spacing="3">
                    <TextBlock Text="Připojení k serveru"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource BrushTextPrimary}"/>
                    <TextBlock Text="Adresa self-hosted AssetMap serveru"
                               FontSize="12"
                               Foreground="{DynamicResource BrushTextSecondary}"/>
                </StackPanel>

                <Border Classes="separator"/>

                <StackPanel Spacing="6">
                    <TextBlock Text="URL serveru"
                               FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource BrushTextSecondary}"/>
                    <Grid ColumnDefinitions="*,12,Auto">
                        <TextBox Grid.Column="0"
                                 Text="{Binding ServerUrl}"
                                 PlaceholderText="http://localhost:5000"/>

                        <Button Grid.Column="2"
                                Classes="secondary"
                                Command="{Binding TestConnectionCommand}"
                                IsEnabled="{Binding !IsTestingConnection}"
                                Padding="14 8">
                            <Panel>
                                <TextBlock Text="Otestovat"
                                           IsVisible="{Binding !IsTestingConnection}"/>
                                <TextBlock Text="Testuji…"
                                           IsVisible="{Binding IsTestingConnection}"/>
                            </Panel>
                        </Button>
                    </Grid>
                </StackPanel>

                <!-- Stav připojení — OK -->
                <Border CornerRadius="4" Padding="10 8"
                        Background="#204EC994"
                        BorderBrush="#404EC994" BorderThickness="1"
                        IsVisible="{Binding ConnectionOk}">
                    <TextBlock Text="{Binding ConnectionStatus}"
                               Foreground="{DynamicResource BrushSuccess}"
                               FontSize="12"/>
                </Border>

                <!-- Stav připojení — chyba -->
                <Border CornerRadius="4" Padding="10 8"
                        Background="#20F14C4C"
                        BorderBrush="#40F14C4C" BorderThickness="1">
                    <Border.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="ConnectionStatus"
                                     Converter="{x:Static StringConverters.IsNotNullOrEmpty}"/>
                            <Binding Path="!ConnectionOk"/>
                        </MultiBinding>
                    </Border.IsVisible>
                    <TextBlock Text="{Binding ConnectionStatus}"
                               Foreground="{DynamicResource BrushDanger}"
                               FontSize="12"/>
                </Border>

            </StackPanel>
        </Border>

        <!-- ══════════ VZHLED ══════════ -->
        <Border Classes="card">
            <StackPanel Spacing="16">

                <TextBlock Text="Vzhled"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource BrushTextPrimary}"/>

                <Border Classes="separator"/>

                <!-- Tmavý / světlý -->
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="Tmavý režim"
                                   FontSize="13" FontWeight="Medium"
                                   Foreground="{DynamicResource BrushTextPrimary}"/>
                        <TextBlock Text="Přepíná mezi tmavým a světlým tématem"
                                   FontSize="12"
                                   Foreground="{DynamicResource BrushTextSecondary}"/>
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1"
                                  IsChecked="{Binding IsDarkTheme}"
                                  OffContent="" OnContent=""
                                  VerticalAlignment="Center"/>
                </Grid>

                <Border Classes="separator"/>

                <!-- Akcentní barva -->
                <StackPanel Spacing="10">
                    <TextBlock Text="Akcentní barva"
                               FontSize="13" FontWeight="Medium"
                               Foreground="{DynamicResource BrushTextPrimary}"/>

                    <StackPanel Orientation="Horizontal" Spacing="12">

                        <StackPanel Spacing="5" HorizontalAlignment="Center">
                            <Button Classes="ghost" Padding="0"
                                    Command="{Binding SetAccentBlueCommand}"
                                    Width="38" Height="38" CornerRadius="19"
                                    ToolTip.Tip="Modrá">
                                <Border Width="26" Height="26" CornerRadius="13"
                                        Background="#0078D4"/>
                            </Button>
                            <TextBlock Text="Modrá" FontSize="10"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Spacing="5" HorizontalAlignment="Center">
                            <Button Classes="ghost" Padding="0"
                                    Command="{Binding SetAccentPurpleCommand}"
                                    Width="38" Height="38" CornerRadius="19"
                                    ToolTip.Tip="Fialová">
                                <Border Width="26" Height="26" CornerRadius="13"
                                        Background="#A371F7"/>
                            </Button>
                            <TextBlock Text="Fialová" FontSize="10"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Spacing="5" HorizontalAlignment="Center">
                            <Button Classes="ghost" Padding="0"
                                    Command="{Binding SetAccentGreenCommand}"
                                    Width="38" Height="38" CornerRadius="19"
                                    ToolTip.Tip="Zelená">
                                <Border Width="26" Height="26" CornerRadius="13"
                                        Background="#4EC994"/>
                            </Button>
                            <TextBlock Text="Zelená" FontSize="10"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Spacing="5" HorizontalAlignment="Center">
                            <Button Classes="ghost" Padding="0"
                                    Command="{Binding SetAccentOrangeCommand}"
                                    Width="38" Height="38" CornerRadius="19"
                                    ToolTip.Tip="Oranžová">
                                <Border Width="26" Height="26" CornerRadius="13"
                                        Background="#CE9178"/>
                            </Button>
                            <TextBlock Text="Oranžová" FontSize="10"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                    </StackPanel>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- ══════════ O APLIKACI ══════════ -->
        <Border Classes="card">
            <StackPanel Spacing="12">
                <TextBlock Text="O aplikaci"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource BrushTextPrimary}"/>

                <Border Classes="separator"/>

                <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Verze"
                               FontSize="13" Foreground="{DynamicResource BrushTextSecondary}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="0.1.0-alpha"
                               FontSize="13" FontWeight="Medium"
                               Foreground="{DynamicResource BrushTextPrimary}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Platforma"
                               FontSize="13" Margin="0 8 0 0"
                               Foreground="{DynamicResource BrushTextSecondary}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Avalonia UI · .NET 10"
                               FontSize="13" FontWeight="Medium" Margin="0 8 0 0"
                               Foreground="{DynamicResource BrushTextPrimary}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Licence"
                               FontSize="13" Margin="0 8 0 0"
                               Foreground="{DynamicResource BrushTextSecondary}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="MIT"
                               FontSize="13" FontWeight="Medium" Margin="0 8 0 0"
                               Foreground="{DynamicResource BrushTextPrimary}"/>
                </Grid>

            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>
