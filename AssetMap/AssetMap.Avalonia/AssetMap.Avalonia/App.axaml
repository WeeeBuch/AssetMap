<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:AssetMap.Avalonia"
             x:Class="AssetMap.Avalonia.App"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Semantic color tokens (light + dark via ThemeDictionaries) -->
                <ResourceInclude Source="avares://AssetMap.Avalonia/Themes/ThemeColors.axaml"/>
                <!-- Active accent — swapped at runtime by ThemeService.SetAccent() -->
                <ResourceInclude Source="avares://AssetMap.Avalonia/Themes/Accents/Blue.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

</Application>