<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="BrushAccent">#00E57A</SolidColorBrush>
    <SolidColorBrush x:Key="BrushAccentHover">#1AFFAA</SolidColorBrush>
    <SolidColorBrush x:Key="BrushAccentPressed">#00BB61</SolidColorBrush>
    <Color x:Key="ColorAccent">#00E57A</Color>
    <Color x:Key="ColorAccentHover">#1AFFAA</Color>
    <Color x:Key="ColorAccentPressed">#00BB61</Color>

</ResourceDictionary>
