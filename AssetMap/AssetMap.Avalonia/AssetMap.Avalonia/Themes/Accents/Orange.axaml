<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="BrushAccent">#FF6B00</SolidColorBrush>
    <SolidColorBrush x:Key="BrushAccentHover">#FF8F33</SolidColorBrush>
    <SolidColorBrush x:Key="BrushAccentPressed">#CC5500</SolidColorBrush>
    <Color x:Key="ColorAccent">#FF6B00</Color>
    <Color x:Key="ColorAccentHover">#FF8F33</Color>
    <Color x:Key="ColorAccentPressed">#CC5500</Color>

</ResourceDictionary>
