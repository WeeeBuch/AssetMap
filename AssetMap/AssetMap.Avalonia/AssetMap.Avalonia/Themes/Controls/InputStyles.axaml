<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════════════════════════════════
         TEXTBOX — base
         ══════════════════════════════════ -->
    <Style Selector="TextBox">
        <Setter Property="Background"      Value="{DynamicResource BrushSurfaceAlt}"/>
        <Setter Property="Foreground"      Value="{DynamicResource BrushTextPrimary}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource BrushBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="4"/>
        <Setter Property="Padding"         Value="10 8"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="MinHeight"       Value="0"/>
        <Setter Property="SelectionBrush"  Value="{DynamicResource BrushAccent}"/>
    </Style>

    <!-- Hover -->
    <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource BrushTextSecondary}"/>
    </Style>

    <!-- Focus — accent border -->
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush"     Value="{DynamicResource BrushAccent}"/>
        <Setter Property="BorderThickness" Value="1 1 1 2"/>
    </Style>

    <!-- Disabled -->
    <Style Selector="TextBox:disabled">
        <Setter Property="Opacity" Value="0.45"/>
    </Style>

    <!-- Placeholder barva — PART_Watermark zůstal interní název i po přejmenování property -->
    <Style Selector="TextBox /template/ TextBlock#PART_Watermark">
        <Setter Property="Foreground" Value="{DynamicResource BrushTextSecondary}"/>
        <Setter Property="Opacity"    Value="0.55"/>
    </Style>
    <!-- Fallback pro verze kde se část přejmenovala -->
    <Style Selector="TextBox /template/ TextBlock#PART_PlaceholderText">
        <Setter Property="Foreground" Value="{DynamicResource BrushTextSecondary}"/>
        <Setter Property="Opacity"    Value="0.55"/>
    </Style>


    <!-- ══════════════════════════════════
         TEXTBOX.error — červený border
         Classes="error"
         ══════════════════════════════════ -->
    <Style Selector="TextBox.error">
        <Setter Property="BorderBrush" Value="{DynamicResource BrushDanger}"/>
    </Style>

    <Style Selector="TextBox.error:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource BrushDanger}"/>
    </Style>


    <!-- ══════════════════════════════════
         COMBOBOX — stejný look jako TextBox
         ══════════════════════════════════ -->

    <!-- Základní vzhled -->
    <Style Selector="ComboBox">
        <Setter Property="Background"      Value="{DynamicResource BrushSurfaceAlt}"/>
        <Setter Property="Foreground"      Value="{DynamicResource BrushTextPrimary}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource BrushBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="4"/>
        <Setter Property="Padding"         Value="10 0 6 0"/>
        <Setter Property="MinHeight"       Value="34"/>
        <Setter Property="FontSize"        Value="13"/>
    </Style>

    <!-- Inner background border -->
    <Style Selector="ComboBox /template/ Border#Background">
        <Setter Property="Background"      Value="{DynamicResource BrushSurfaceAlt}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource BrushBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="4"/>
    </Style>

    <!-- Hover -->
    <Style Selector="ComboBox:pointerover /template/ Border#Background">
        <Setter Property="BorderBrush" Value="{DynamicResource BrushTextSecondary}"/>
        <Setter Property="Background"  Value="{DynamicResource BrushSurfaceAlt}"/>
    </Style>

    <!-- Otevřeno / focus -->
    <Style Selector="ComboBox:focus-within /template/ Border#Background">
        <Setter Property="BorderBrush"     Value="{DynamicResource BrushAccent}"/>
        <Setter Property="BorderThickness" Value="1 1 1 2"/>
    </Style>

    <!-- Šipka v ComboBox — barva textu -->
    <Style Selector="ComboBox /template/ PathIcon">
        <Setter Property="Foreground" Value="{DynamicResource BrushTextSecondary}"/>
    </Style>

    <!-- Popup — tmavé pozadí -->
    <Style Selector="ComboBox /template/ Popup /template/ Border">
        <Setter Property="Background"   Value="{DynamicResource BrushSurface}"/>
        <Setter Property="BorderBrush"  Value="{DynamicResource BrushBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="BoxShadow"    Value="0 4 20 0 #50000000"/>
    </Style>

    <!-- Položky v dropdownu -->
    <Style Selector="ComboBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
        <Setter Property="FontSize"   Value="13"/>
        <Setter Property="Padding"    Value="10 7"/>
        <Setter Property="MinHeight"  Value="0"/>
    </Style>
    <Style Selector="ComboBoxItem /template/ ContentPresenter">
        <Setter Property="Background"   Value="Transparent"/>
        <Setter Property="CornerRadius" Value="3"/>
    </Style>
    <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrushSurfaceAlt}"/>
    </Style>
    <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrushAccent}"/>
    </Style>
    <Style Selector="ComboBoxItem:selected">
        <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="ComboBoxItem:selected:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrushAccentHover}"/>
    </Style>


    <!-- ══════════════════════════════════
         TOGGLESWITCH — accent barva místo FluentTheme modré
         Track part = Border#SwitchKnobBounds
         Generické (base) styly musí být PŘED pseudo-class override.
         ══════════════════════════════════ -->

    <!-- Unchecked — tmavší track (FluentTheme default je příliš světlý) -->
    <Style Selector="ToggleSwitch /template/ Border#SwitchKnobBounds">
        <Setter Property="Background"      Value="{DynamicResource BrushSurfaceAlt}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource BrushBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- Unchecked + hover -->
    <Style Selector="ToggleSwitch:pointerover /template/ Border#SwitchKnobBounds">
        <Setter Property="Background" Value="{DynamicResource BrushBorder}"/>
    </Style>

    <!-- Checked — accent barva -->
    <Style Selector="ToggleSwitch:checked /template/ Border#SwitchKnobBounds">
        <Setter Property="Background"      Value="{DynamicResource BrushAccent}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource BrushAccent}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- Checked + hover -->
    <Style Selector="ToggleSwitch:checked:pointerover /template/ Border#SwitchKnobBounds">
        <Setter Property="Background"  Value="{DynamicResource BrushAccentHover}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BrushAccentHover}"/>
    </Style>

    <!-- Checked + pressed -->
    <Style Selector="ToggleSwitch:checked:pressed /template/ Border#SwitchKnobBounds">
        <Setter Property="Background"  Value="{DynamicResource BrushAccentPressed}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BrushAccentPressed}"/>
    </Style>

</Styles>
